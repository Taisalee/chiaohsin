---
import Layout from "../../layouts/Layout.astro";
import ProductCard from "../../components/ProductCard.astro";
import company from "../../data/company.json";
import categories from "../../data/categories.json";
import products from "../../data/products.json";
import seo from "../../data/seo.json";

export function getStaticPaths() {
    return products
        .filter((product) => product.available !== false)
        .map((product) => {
            const category = categories.find((c) => c.id === product.category);
            return {
                params: { id: product.id },
                props: { product, category },
            };
        });
}

interface Props {
    product: (typeof products)[0];
    category: (typeof categories)[0];
}

const { product, category } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? "https://chiaohsin.com.tw";

// 超商零售連結（選填欄位，無值則不顯示零售區塊）
const retailLinks = (product as any).retailLinks as { "711"?: string; family?: string } | undefined;

// 取得同分類的其他產品作為相關產品
const relatedProducts = products
    .filter((p) => p.category === product.category && p.id !== product.id && p.available !== false)
    .slice(0, 4);

// SEO 相關設定
const productTitle = `${product.name} - ${category.name}`;
const _descFirstSentence = product.description.replace(/\n+/g, ' ').split('。')[0];
const _descSnippet = _descFirstSentence.length > 80 ? _descFirstSentence.slice(0, 80) + '…' : _descFirstSentence;
const productDescription = `${product.name}｜${category.name}批發直供。${_descSnippet}。喬新針織，全台配送。`.slice(0, 155);
// 產品專屬關鍵字：產品名、分類名、tags（同義詞）
const productKeywords = [product.name, category.name, ...(product.tags || [])];

// 結構化資料 (JSON-LD)
const structuredData = {
    "@context": "https://schema.org",
    "@type": "Product",
    "@id": `${siteUrl}/products/${product.id}`,
    name: product.name,
    description: product.description,
    image: [`${siteUrl}/${product.image}`],
    url: `${siteUrl}/products/${product.id}`,
    sku: product.id,
    category: category.name,
    ...(product.materials && { material: product.materials }),
    ...(product.size && product.size !== "-" && { size: product.size }),
    ...(product.weight && { weight: { "@type": "QuantitativeValue", name: product.weight } }),
    brand: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        foundingDate: "2003",
    },
    manufacturer: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        url: `https://${company.website}`,
        foundingDate: "2003",
    },
    dateModified: new Date().toISOString().split("T")[0],
    offers: {
        "@type": "Offer",
        url: `${siteUrl}/products/${product.id}`,
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        priceSpecification: {
            "@type": "PriceSpecification",
            priceCurrency: "TWD",
            description: "批發價格依數量而定，請洽詢業務",
        },
        seller: {
            "@type": "Organization",
            "@id": `${siteUrl}/#organization`,
            name: company.shortName,
        },
    },
};

// FAQ 結構化資料
const faqItems = [
    ...(product.materials ? [{
        "@type": "Question",
        name: `${product.name} 的材質成分是什麼？`,
        acceptedAnswer: { "@type": "Answer", text: product.materials },
    }] : []),
    ...(product.packaging ? [{
        "@type": "Question",
        name: `${product.name} 的包裝規格為何？`,
        acceptedAnswer: { "@type": "Answer", text: product.packaging },
    }] : []),
    ...((product as any).targetIndustries?.length > 0 ? [{
        "@type": "Question",
        name: `${product.name} 適合哪些行業或場合使用？`,
        acceptedAnswer: { "@type": "Answer", text: (product as any).targetIndustries.join("、") },
    }] : []),
    ...((product as any).targetAudiences?.length > 0 ? [{
        "@type": "Question",
        name: `${product.name} 適合哪些工作崗位使用？`,
        acceptedAnswer: {
            "@type": "Answer",
            text: `本產品適合以下工作人員配戴使用：${(product as any).targetAudiences.join("、")}。如有大量採購需求，歡迎洽詢喬新針織取得批發報價。`,
        },
    }] : []),
    {
        "@type": "Question",
        name: `如何批發購買 ${product.name}？`,
        acceptedAnswer: {
            "@type": "Answer",
            text: `可透過 LINE（ID：ulh0933098358）或電話（${company.contact.phone}）聯絡喬新針織業務，洽談批發報價與出貨事宜。`,
        },
    },
    {
        "@type": "Question",
        name: `購買 ${product.name} 是否有量大優惠？`,
        acceptedAnswer: {
            "@type": "Answer",
            text: "喬新針織提供量大優惠，訂購數量越多折扣越好，詳細價格請來電或 LINE 洽詢。",
        },
    },
];
const faqData = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems,
};

// 麵包屑結構化資料
const breadcrumbData = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "首頁",
            item: `${siteUrl}/`,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "產品介紹",
            item: `${siteUrl}/products`,
        },
        {
            "@type": "ListItem",
            position: 3,
            name: category.name,
            item: `${siteUrl}/products#${category.id}`,
        },
        {
            "@type": "ListItem",
            position: 4,
            name: product.name,
            item: `${siteUrl}/products/${product.id}`,
        },
    ],
};
---

<Layout
    title={productTitle}
    description={productDescription}
    keywords={productKeywords}
    canonical={`/products/${product.id}`}
    ogImage={`/${product.image}`}
    ogType="product"
>
    <!-- 結構化資料 -->
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(breadcrumbData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqData)}
        />
    </Fragment>

    <div class="min-h-screen bg-base-100">
        <!-- 麵包屑導航 -->
        <nav class="bg-base-200 py-3 px-4 md:px-10" aria-label="麵包屑">
            <div class="max-w-7xl mx-auto">
                <ol
                    class="breadcrumbs text-sm flex flex-wrap items-center gap-2"
                    itemscope
                    itemtype="https://schema.org/BreadcrumbList"
                >
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a href="/" itemprop="item" class="link link-hover">
                            <span itemprop="name">首頁</span>
                        </a>
                        <meta itemprop="position" content="1" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a
                            href="/products"
                            itemprop="item"
                            class="link link-hover"
                        >
                            <span itemprop="name">產品介紹</span>
                        </a>
                        <meta itemprop="position" content="2" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a
                            href={`/products#${category.id}`}
                            itemprop="item"
                            class="link link-hover"
                        >
                            <span itemprop="name">{category.name}</span>
                        </a>
                        <meta itemprop="position" content="3" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                        class="text-primary font-medium"
                    >
                        <span itemprop="name">{product.name}</span>
                        <meta itemprop="position" content="4" />
                    </li>
                </ol>
            </div>
        </nav>

        <!-- 產品詳情 -->
        <article class="max-w-7xl mx-auto px-4 md:px-10 py-8 md:py-12">
            <!-- 手機版：分類 + 名稱 先顯示 -->
            <div class="lg:hidden mb-6">
                <!-- 分類標籤 -->
                <div class="flex items-center gap-2 mb-3">
                    <a
                        href={`/products#${category.id}`}
                        class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold hover:bg-blue-200 transition-colors"
                    >
                        {category.name}
                    </a>
                </div>
                <!-- 產品名稱 -->
                <h1 class="text-3xl font-black leading-snug">
                    {product.name}
                </h1>
                <!-- 規格尺寸 -->
                {
                    product.size && product.size !== "-" && (
                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-gray-500 text-sm">
                                規格尺寸：
                            </span>
                            <span class="badge badge-outline">
                                {product.size === "F" ? "F（均碼）" : product.size}
                            </span>
                        </div>
                    )
                }
                <!-- 手機版：產品特色標籤（移到圖片上面，最多顯示 2 個） -->
                {
                    product.features && product.features.length > 0 && (
                        <div class="mobile-features flex flex-wrap gap-2 mt-3">
                            {product.features.map((feature: string) => (
                                <span class="feature-badge">
                                    ✓ {feature}
                                </span>
                            ))}
                        </div>
                    )
                }
            </div>

            <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
                <!-- 產品圖片 + 規格表 -->
                <div class="flex-1 lg:sticky lg:top-24 self-start">
                    <figure
                        class="bg-base-200 rounded-2xl lg:p-8 flex items-center justify-center lg:min-h-[400px]"
                    >
                        <img
                            src={`/${product.image}`}
                            alt={`${product.name} 產品圖片`}
                            class="w-full lg:max-h-[500px] object-contain rounded-xl shadow-lg"
                            width="500"
                            height="500"
                            loading="eager"
                        />
                    </figure>

                </div>

                <!-- 產品資訊 -->
                <div class="flex-1 space-y-4 md:space-y-6">
                    <!-- 電腦版：分類標籤 -->
                    <div class="hidden lg:flex items-center gap-2">
                        <a
                            href={`/products#${category.id}`}
                            class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold hover:bg-blue-200 transition-colors"
                        >
                            {category.name}
                        </a>
                    </div>

                    <!-- 電腦版：產品名稱 -->
                    <h1
                        class="hidden lg:block text-4xl font-black leading-snug"
                        aria-hidden="true"
                    >
                        {product.name}
                    </h1>

                    <!-- 產品特色標籤 (電腦版顯示) -->
                    {
                        product.features && product.features.length > 0 && (
                            <div class="hidden lg:flex flex-wrap gap-2 pt-2">
                                {product.features.map((feature: string) => (
                                    <span class="feature-badge">
                                        ✓ {feature}
                                    </span>
                                ))}
                            </div>
                        )
                    }

                    <!-- 產品規格表格 -->
                    {
                        (product.materials ||
                            product.packaging ||
                            product.weight ||
                            product.specifications) && (
                            <div>
                                <p class="section-label">產品規格</p>
                                <div class="rounded-xl border border-gray-200 overflow-hidden spec-table-wrap">
                                    <table class="w-full text-sm lg:text-base">
                                        <tbody class="divide-y divide-gray-100">
                                            {product.materials && (
                                                <tr>
                                                    <td class="px-4 py-3 font-semibold text-gray-700 w-1/3">
                                                        材質成分
                                                    </td>
                                                    <td class="px-4 py-3 text-gray-600">{product.materials}</td>
                                                </tr>
                                            )}
                                            {product.size &&
                                                product.size !== "-" &&
                                                !product.specifications && (
                                                    <tr>
                                                        <td class="px-4 py-3 font-semibold text-gray-700">
                                                            尺寸規格
                                                        </td>
                                                        <td class="px-4 py-3 text-gray-600">{product.size === "F" ? "F（均碼）" : product.size}</td>
                                                    </tr>
                                                )}
                                            {product.packaging && (
                                                <tr>
                                                    <td class="px-4 py-3 font-semibold text-gray-700">
                                                        包裝規格
                                                    </td>
                                                    <td class="px-4 py-3 text-gray-600">{product.packaging}</td>
                                                </tr>
                                            )}
                                            {product.weight && (
                                                <tr>
                                                    <td class="px-4 py-3 font-semibold text-gray-700">
                                                        重量
                                                    </td>
                                                    <td class="px-4 py-3 text-gray-600">{product.weight}</td>
                                                </tr>
                                            )}
                                            {product.specifications &&
                                                Object.entries(
                                                    product.specifications,
                                                ).map(([key, value]) => (
                                                    <tr>
                                                        <td class="px-4 py-3 font-semibold text-gray-700 w-1/3">
                                                            {key}
                                                        </td>
                                                        <td class="px-4 py-3 text-gray-600">{value}</td>
                                                    </tr>
                                                ))}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        )
                    }

                    <!-- CTA 按鈕區塊 -->
                    <div class="space-y-2 pt-4" id="cta-block">
                        <!-- 主 CTA：LINE + 電話 -->
                        <div class="grid grid-cols-2 gap-3">
                            <a
                                href="https://line.me/ti/p/~ulh0933098358"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-lg border-0 shadow-lg shadow-green-500/20 text-white hover:scale-[1.02] active:scale-95 transition-all rounded-xl gap-2"
                                style="background: linear-gradient(135deg, #06C755 0%, #05a346 100%);"
                            >
                                <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current flex-shrink-0" xmlns="http://www.w3.org/2000/svg">
                                    <path fill-rule="evenodd" d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"></path>
                                </svg>
                                LINE 洽詢
                            </a>
                            <a
                                href={`tel:${company.contact.phone}`}
                                class="btn btn-lg border-0 shadow-lg shadow-blue-500/20 text-white hover:scale-[1.02] active:scale-95 transition-all rounded-xl gap-2"
                                style="background: linear-gradient(135deg, #0066CC 0%, #0052a3 100%);"
                            >
                                <svg class="h-5 w-5 fill-current flex-shrink-0" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z" clip-rule="evenodd"/>
                                </svg>
                                立即電話
                            </a>
                        </div>

                        <!-- 信任標章 -->
                        <div class="flex items-center justify-center gap-3 py-1 text-xs text-gray-400 flex-wrap">
                            <span>✅ 台南工廠直營</span>
                            <span>✅ 全台配送</span>
                            <span>✅ 成立 2003 年</span>
                            <span>✅ 量大另有折扣</span>
                        </div>

                        <!-- 超商零售（有 retailLinks 才顯示） -->
                        {retailLinks && (retailLinks["711"] || retailLinks.family) && (
                            <div class="pt-1">
                                <div class="flex items-center gap-3">
                                    <div class="flex-1 border-t border-gray-100"></div>
                                    <span class="text-xs text-gray-300 whitespace-nowrap">也可在超商零售購買</span>
                                    <div class="flex-1 border-t border-gray-100"></div>
                                </div>
                                <div class="grid gap-2 mt-2" style={`grid-template-columns: repeat(${[retailLinks["711"], retailLinks.family].filter(Boolean).length}, 1fr)`}>
                                    {retailLinks["711"] && (
                                        <a href={retailLinks["711"]} target="_blank" rel="noopener noreferrer"
                                            class="flex flex-col items-center justify-center py-3.5 rounded-xl border border-gray-200 bg-white hover:border-gray-300 transition-colors gap-1">
                                            <span class="font-black text-base" style="color:#007340;">7-ELEVEN</span>
                                            <span class="text-gray-400 text-xs">賣貨便</span>
                                        </a>
                                    )}
                                    {retailLinks.family && (
                                        <a href={retailLinks.family} target="_blank" rel="noopener noreferrer"
                                            class="flex flex-col items-center justify-center py-3.5 rounded-xl border border-gray-200 bg-white hover:border-gray-300 transition-colors gap-1">
                                            <span class="font-black text-base" style="color:#00AEEF;">全家 FamilyMart</span>
                                            <span class="text-gray-400 text-xs">好賣+</span>
                                        </a>
                                    )}
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>

            <!-- 次要資訊：適用對象/行業 + 產品說明（全寬） -->
            {
                (product.targetIndustries?.length > 0 ||
                    product.description) && (
                    <div class="mt-5 pt-5 md:mt-10 md:pt-8 border-t border-base-300 space-y-5 md:space-y-8">
                        {product.targetIndustries?.length > 0 && (
                            <div>
                                <p class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-3">適合對象</p>
                                <div class="flex flex-wrap gap-2">
                                    {product.targetIndustries?.map((industry: string) => (
                                        <span class="inline-flex items-center px-3 py-1.5 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700 font-medium">
                                            {industry}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}
                        <div class="prose prose-lg max-w-none">
                            <h2 class="text-xl font-semibold mb-3">產品說明</h2>
                            {(product.description || "")
                                .split("\n")
                                .map(
                                    (paragraph) =>
                                        paragraph.trim() && (
                                            <p class="text-gray-600 leading-relaxed mb-4">
                                                {paragraph}
                                            </p>
                                        ),
                                )}
                        </div>
                    </div>
                )
            }

            <!-- FAQ 區塊 -->
            <div class="mt-5 pt-5 md:mt-10 md:pt-8 border-t border-gray-100">
                <p class="section-label">常見問題</p>
                <div class="space-y-2">
                    {faqItems.map((item) => (
                        <details class="group rounded-xl border border-gray-200 overflow-hidden bg-gray-50">
                            <summary class="faq-summary flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-gray-800 hover:bg-gray-100 transition-colors">
                                {item.name}
                                <svg class="h-4 w-4 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-3" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                </svg>
                            </summary>
                            <div class="px-5 py-4 text-gray-600 text-sm leading-relaxed border-t border-gray-100 bg-white">
                                {item.acceptedAnswer.text}
                            </div>
                        </details>
                    ))}
                </div>
            </div>
        </article>

        <!-- 相關產品 -->
        {
            relatedProducts.length > 0 && (
                <section class="mt-2 pt-4 md:mt-16 md:pt-8 border-t border-base-300 max-w-7xl mx-auto px-4 md:px-10">
                    <h2 class="text-2xl font-bold mb-5 md:mb-8 flex items-center gap-3">
                        其他{category.name}產品
                    </h2>
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                        {relatedProducts.map((p) => (
                            <ProductCard
                                id={p.id}
                                name={p.name}
                                image={p.image}
                                description={p.description}
                                size={p.size}
                                category={p.category}
                                tags={(p as any).tags || []}
                                categoryName={category.name}
                            />
                        ))}
                    </div>
                    <div class="text-center mt-8">
                        <a
                            href={`/products#${category.id}`}
                            class="btn btn-outline"
                        >
