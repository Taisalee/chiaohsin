---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";
import categories from "../../data/categories.json";
import products from "../../data/products.json";
import seo from "../../data/seo.json";

export function getStaticPaths() {
    return products
        .filter((product) => product.available !== false)
        .map((product) => {
            const category = categories.find((c) => c.id === product.category);
            return {
                params: { id: product.id },
                props: { product, category },
            };
        });
}

interface Props {
    product: (typeof products)[0];
    category: (typeof categories)[0];
}

const { product, category } = Astro.props;

const siteUrl = "https://www.chiaohsin.com.tw";

// 取得同分類的其他產品作為相關產品
const relatedProducts = products
    .filter((p) => p.category === product.category && p.id !== product.id && p.available !== false)
    .slice(0, 3);

// SEO 相關設定
const productTitle = `${product.name} - ${category.name}`;
const _descFirstSentence = product.description.replace(/\n+/g, ' ').split('。')[0];
const _descSnippet = _descFirstSentence.length > 80 ? _descFirstSentence.slice(0, 80) + '…' : _descFirstSentence;
const productDescription = `${product.name}｜${category.name}批發直供。${_descSnippet}。喬新針織，全台配送。`.slice(0, 155);
// 產品專屬關鍵字：產品名、分類名、tags（同義詞）
const productKeywords = [product.name, category.name, ...(product.tags || [])];

// 結構化資料 (JSON-LD)
const structuredData = {
    "@context": "https://schema.org",
    "@type": "Product",
    "@id": `${siteUrl}/products/${product.id}`,
    name: product.name,
    description: product.description,
    image: `${siteUrl}/${product.image}`,
    url: `${siteUrl}/products/${product.id}`,
    sku: product.id,
    category: category.name,
    ...(product.materials && { material: product.materials }),
    ...(product.size && product.size !== "-" && { size: product.size }),
    brand: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
    },
    manufacturer: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        url: `https://${company.website}`,
    },
    offers: {
        "@type": "Offer",
        url: `${siteUrl}/products/${product.id}`,
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        seller: {
            "@type": "Organization",
            "@id": `${siteUrl}/#organization`,
            name: company.shortName,
        },
    },
};

// 麵包屑結構化資料
const breadcrumbData = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "首頁",
            item: "https://www.chiaohsin.com.tw/",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "產品介紹",
            item: "https://www.chiaohsin.com.tw/products",
        },
        {
            "@type": "ListItem",
            position: 3,
            name: category.name,
            item: `https://www.chiaohsin.com.tw/products#${category.id}`,
        },
        {
            "@type": "ListItem",
            position: 4,
            name: product.name,
            item: `https://www.chiaohsin.com.tw/products/${product.id}`,
        },
    ],
};
---

<Layout
    title={productTitle}
    description={productDescription}
    keywords={productKeywords}
    canonical={`/products/${product.id}`}
    ogImage={`/${product.image}`}
    ogType="product"
>
    <!-- 結構化資料 -->
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(breadcrumbData)}
        />
    </Fragment>

    <div class="min-h-screen bg-base-100">
        <!-- 麵包屑導航 -->
        <nav class="bg-base-200 py-3 px-4 md:px-10" aria-label="麵包屑">
            <div class="max-w-7xl mx-auto">
                <ol
                    class="breadcrumbs text-sm flex flex-wrap items-center gap-2"
                    itemscope
                    itemtype="https://schema.org/BreadcrumbList"
                >
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a href="/" itemprop="item" class="link link-hover">
                            <span itemprop="name">首頁</span>
                        </a>
                        <meta itemprop="position" content="1" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a
                            href="/products"
                            itemprop="item"
                            class="link link-hover"
                        >
                            <span itemprop="name">產品介紹</span>
                        </a>
                        <meta itemprop="position" content="2" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                    >
                        <a
                            href={`/products#${category.id}`}
                            itemprop="item"
                            class="link link-hover"
                        >
                            <span itemprop="name">{category.name}</span>
                        </a>
                        <meta itemprop="position" content="3" />
                    </li>
                    <li class="text-gray-400">/</li>
                    <li
                        itemprop="itemListElement"
                        itemscope
                        itemtype="https://schema.org/ListItem"
                        class="text-primary font-medium"
                    >
                        <span itemprop="name">{product.name}</span>
                        <meta itemprop="position" content="4" />
                    </li>
                </ol>
            </div>
        </nav>

        <!-- 產品詳情 -->
        <article class="max-w-7xl mx-auto px-4 md:px-10 py-8 md:py-12">
            <!-- 手機版：分類 + 名稱 先顯示 -->
            <div class="lg:hidden mb-6">
                <!-- 分類標籤 -->
                <div class="flex items-center gap-2 mb-3">
                    <a
                        href={`/products#${category.id}`}
                        class="badge badge-primary badge-lg hover:badge-secondary transition-colors text-white"
                    >
                        {category.name}
                    </a>
                </div>
                <!-- 產品名稱 -->
                <h1 class="text-3xl font-bold leading-tight">
                    {product.name}
                </h1>
                <!-- 規格尺寸 -->
                {
                    product.size && product.size !== "-" && (
                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-gray-500 text-sm">
                                規格尺寸：
                            </span>
                            <span class="badge badge-outline">
                                {product.size}
                            </span>
                        </div>
                    )
                }
                <!-- 手機版：產品特色標籤（移到圖片上面）-->
                {
                    product.features && product.features.length > 0 && (
                        <div class="flex flex-wrap gap-2 mt-3">
                            {product.features.map((feature: string) => (
                                <span class="badge badge-primary badge-lg gap-1">
                                    ✓ {feature}
                                </span>
                            ))}
                        </div>
                    )
                }
            </div>

            <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
                <!-- 產品圖片 + 規格表 -->
                <div class="flex-1 lg:sticky lg:top-24 self-start">
                    <figure
                        class="bg-base-200 rounded-2xl lg:p-8 flex items-center justify-center lg:min-h-[400px]"
                    >
                        <img
                            src={`/${product.image}`}
                            alt={`${product.name} 產品圖片`}
                            class="w-full lg:max-h-[500px] object-contain rounded-xl shadow-lg"
                            width="500"
                            height="500"
                            loading="eager"
                        />
                    </figure>

                    <!-- 產品規格表格 -->
                    {
                        (product.materials ||
                            product.packaging ||
                            product.weight ||
                            product.specifications) && (
                            <div class="overflow-x-auto mt-4 lg:mt-6">
                                <table class="table table-zebra w-full text-sm lg:text-base">
                                    <thead>
                                        <tr>
                                            <th
                                                colspan="2"
                                                class="bg-base-200 text-base lg:text-lg"
                                            >
                                                📋 產品規格
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {product.materials && (
                                            <tr>
                                                <td class="font-medium w-1/3">
                                                    材質成分
                                                </td>
                                                <td>{product.materials}</td>
                                            </tr>
                                        )}
                                        {product.size &&
                                            product.size !== "-" &&
                                            !product.specifications && (
                                                <tr>
                                                    <td class="font-medium">
                                                        尺寸規格
                                                    </td>
                                                    <td>{product.size}</td>
                                                </tr>
                                            )}
                                        {product.packaging && (
                                            <tr>
                                                <td class="font-medium">
                                                    包裝規格
                                                </td>
                                                <td>{product.packaging}</td>
                                            </tr>
                                        )}
                                        {product.weight && (
                                            <tr>
                                                <td class="font-medium">
                                                    重量
                                                </td>
                                                <td>{product.weight}</td>
                                            </tr>
                                        )}
                                        {product.specifications &&
                                            Object.entries(
                                                product.specifications,
                                            ).map(([key, value]) => (
                                                <tr>
                                                    <td class="font-medium w-1/3">
                                                        {key}
                                                    </td>
                                                    <td>{value}</td>
                                                </tr>
                                            ))}
                                    </tbody>
                                </table>
                            </div>
                        )
                    }
                </div>

                <!-- 產品資訊 -->
                <div class="flex-1 space-y-6">
                    <!-- 電腦版：分類標籤 -->
                    <div class="hidden lg:flex items-center gap-2">
                        <a
                            href={`/products#${category.id}`}
                            class="badge badge-primary badge-lg hover:badge-secondary transition-colors text-white"
                        >
                            {category.name}
                        </a>
                    </div>

                    <!-- 電腦版：產品名稱 -->
                    <h1
                        class="hidden lg:block text-4xl md:text-5xl font-bold leading-tight"
                    >
                        {product.name}
                    </h1>

                    <!-- 電腦版：產品規格 -->
                    {
                        product.size && product.size !== "-" && (
                            <div class="hidden lg:flex items-center gap-2">
                                <span class="text-gray-500">規格尺寸：</span>
                                <span class="badge badge-outline badge-lg">
                                    {product.size}
                                </span>
                            </div>
                        )
                    }

                    <!-- 產品特色標籤 (電腦版顯示) -->
                    {
                        product.features && product.features.length > 0 && (
                            <div class="hidden lg:flex flex-wrap gap-2 pt-2">
                                {product.features.map((feature: string) => (
                                    <span class="badge badge-primary badge-lg gap-1">
                                        ✓ {feature}
                                    </span>
                                ))}
                            </div>
                        )
                    }

                    <!-- 適用對象 -->
                    {
                        product.targetAudiences &&
                            product.targetAudiences.length > 0 && (
                                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-base-200 dark:to-base-300 rounded-xl p-5 border border-blue-100 dark:border-base-300">
                                    <h3 class="font-semibold mb-3 flex items-center gap-2 text-blue-700 dark:text-blue-300">
                                        <span class="text-xl">👷</span>
                                        適用對象
                                    </h3>
                                    <div class="flex flex-wrap gap-2">
                                        {product.targetAudiences.map(
                                            (audience: string) => (
                                                <span class="badge badge-outline badge-lg">
                                                    {audience}
                                                </span>
                                            ),
                                        )}
                                    </div>
                                </div>
                            )
                    }

                    <!-- 適用行業 -->
                    {
                        product.targetIndustries &&
                            product.targetIndustries.length > 0 && (
                                <div class="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-base-200 dark:to-base-300 rounded-xl p-5 border border-green-100 dark:border-base-300">
                                    <h3 class="font-semibold mb-3 flex items-center gap-2 text-green-700 dark:text-green-300">
                                        <span class="text-xl">🏭</span>
                                        適用行業
                                    </h3>
                                    <div class="flex flex-wrap gap-2">
                                        {product.targetIndustries.map(
                                            (industry: string) => (
                                                <span class="badge badge-outline badge-lg">
                                                    {industry}
                                                </span>
                                            ),
                                        )}
                                    </div>
                                </div>
                            )
                    }

                    <!-- 產品說明 (全裝置顯示) -->
                    <div class="prose prose-lg max-w-none">
                        <h2 class="text-xl font-semibold mb-3">產品說明</h2>
                        {
                            (product.description || "")
                                .split("\n")
                                .map(
                                    (paragraph) =>
                                        paragraph.trim() && (
                                            <p class="text-gray-600 leading-relaxed mb-4">
                                                {paragraph}
                                            </p>
                                        ),
                                )
                        }
                    </div>

                    <!-- 批量採購提示 (復原) -->
                    <div
                        class="alert bg-gradient-to-r from-orange-100 to-amber-100 border border-orange-200 shadow-md"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="stroke-orange-600 shrink-0 h-6 w-6"
                            fill="none"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        <div>
                            <h4 class="font-bold text-orange-800">
                                💼 企業大量採購享優惠
                            </h4>
                            <p class="text-sm text-orange-700">
                                歡迎公司行號、工廠批量訂購，量大另有折扣，請來電洽詢！
                            </p>
                        </div>
                    </div>
                    <!-- CTA 按鈕區塊 -->
                    <div class="space-y-4 pt-4">
                        <!-- 線上購買專區 (並排顯示) -->
                        <div class="grid grid-cols-2 gap-3">
                            <!-- 賣貨便 -->
                            <a
                                href="https://myship.7-11.com.tw/general/detail/GM2101143624321"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn h-auto py-3 px-2 border-0 shadow-lg shadow-green-500/20 text-white flex flex-col items-center gap-1 hover:scale-[1.02] active:scale-95 transition-all rounded-xl"
                                style="background: linear-gradient(145deg, #21903E 0%, #007C36 100%);"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                                    ></path>
                                </svg>
                                <span class="text-sm font-medium"
                                    >7-11 賣貨便</span
                                >
                            </a>

                            <!-- 好賣+ -->
                            <a
                                href="https://famistore.famiport.com.tw/users/6035178"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn h-auto py-3 px-2 border-0 shadow-lg shadow-blue-500/20 text-white flex flex-col items-center gap-1 hover:scale-[1.02] active:scale-95 transition-all rounded-xl"
                                style="background: linear-gradient(145deg, #00AEEF 0%, #0077c8 100%);"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-6 w-6"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
                                    ></path>
                                </svg>
                                <span class="text-sm font-medium"
                                    >全家 好賣+</span
                                >
                            </a>
                        </div>

                        <!-- 聯絡 buttons -->
                        <div class="flex flex-col sm:flex-row gap-3">
                            <a
                                href={`tel:${company.contact.phone}`}
                                class="btn btn-lg flex-1 border-0 shadow-lg shadow-violet-500/20 text-white hover:scale-[1.02] active:scale-95 transition-all rounded-xl"
                                style="background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);"
                            >
                                <span class="text-xl">📞</span> 立即洽詢
                            </a>
                            <a
                                href="https://line.me/ti/p/~ulh0933098358"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn btn-lg flex-1 border-0 shadow-lg shadow-green-500/20 text-white hover:scale-[1.02] active:scale-95 transition-all rounded-xl"
                                style="background: linear-gradient(135deg, #06C755 0%, #05a346 100%);"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    class="h-8 w-8 fill-current"
                                    xmlns="http://www.w3.org/2000/svg"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
                                    ></path>
                                </svg>
                                LINE 洽詢
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </article>

        <!-- 相關產品 -->
        {
            relatedProducts.length > 0 && (
                <section class="mt-16 pt-8 border-t border-base-300">
                    <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
                        其他{category.name}產品
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {relatedProducts.map((relatedProduct) => (
                            <a
                                href={`/products/${relatedProduct.id}`}
                                class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 border border-base-200 group hover:-translate-y-1"
                            >
                                <figure class="px-4 pt-4 bg-base-200/50 min-h-[160px] flex items-center justify-center overflow-hidden">
                                    <img
                                        src={`/${relatedProduct.image}`}
                                        alt={`${relatedProduct.name} 產品圖片`}
                                        class="rounded-xl h-40 object-contain group-hover:scale-105 transition-transform duration-300"
                                        loading="lazy"
                                        width="200"
                                        height="160"
                                    />
                                </figure>
                                <div class="card-body">
                                    <h3 class="card-title text-lg">
                                        {relatedProduct.name}
                                        {relatedProduct.size &&
                                            relatedProduct.size !== "-" && (
                                                <span class="badge badge-outline text-xs">
                                                    {relatedProduct.size}
                                                </span>
                                            )}
                                    </h3>
                                    <p class="text-sm text-gray-500 line-clamp-2">
                                        {relatedProduct.description}
                                    </p>
                                </div>
                            </a>
                        ))}
                    </div>
                    <div class="text-center mt-8">
                        <a
                            href={`/products#${category.id}`}
                            class="btn btn-outline"
                        >
                            查看所有{category.name} →
                        </a>
                    </div>
                </section>
            )
        }

        <!-- 返回連結 -->
        <div class="mt-12 pt-8 border-t border-base-300">
            <a href="/products" class="btn btn-ghost gap-2"> ← 返回產品列表 </a>
        </div>
    </div>
</Layout>

<style>
    .breadcrumbs li {
        display: inline-flex;
        align-items: center;
    }
</style>
