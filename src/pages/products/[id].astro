<script>
    const ctaBlock = document.getElementById('cta-block');
    const stickyCta = document.getElementById('sticky-cta');
    if (ctaBlock && stickyCta) {
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (!e.isIntersecting) stickyCta.classList.remove('translate-y-full');
                else stickyCta.classList.add('translate-y-full');
            });
        }, { threshold: 0.1 });
        observer.observe(ctaBlock);
    }
</script>
