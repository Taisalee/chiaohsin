---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";
import categories from "../../data/categories.json";
import products from "../../data/products.json";
import seo from "../../data/seo.json";

const siteUrl = "https://www.chiaohsin.com.tw";

const productsDescription = `成立 2003 年・台南廠商直營，提供棉紗手套、NBR/PVC 膠手套、尼龍手套、口罩、太空包等 14 大類工安耗材批發。質量足重、全台配送、客製規格接單，歡迎企業詢價。`;

const availableCategories = categories.filter((cat) =>
  products.some((p) => p.category === cat.id && p.available !== false)
);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${company.shortName}產品分類`,
  url: `${siteUrl}/products`,
  numberOfItems: availableCategories.length,
  itemListElement: availableCategories.map((cat, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: cat.name,
    url: `${siteUrl}/products#${cat.id}`,
    item: {
      "@type": "Product",
      name: cat.name,
      description: cat.description,
      url: `${siteUrl}/products#${cat.id}`,
      brand: { "@type": "Brand", name: company.shortName },
      offers: {
        "@type": "Offer",
        priceCurrency: "TWD",
        availability: "https://schema.org/InStock",
        seller: { "@type": "Organization", name: company.shortName },
        url: `${siteUrl}/contact`,
      },
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "商品介紹", item: `${siteUrl}/products` },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "棉紗手套幾兩才夠用？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "一般工地搬運建議選 20 兩，重工場合可選 24 兩，含棉量高者更舒適耐用。喬新針織（紅螞蟻手套）提供多種重量規格，支援大量批發採購。",
      },
    },
    {
      "@type": "Question",
      name: "NBR 手套和 PVC 手套有什麼差別？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "NBR（丁腈橡膠）手套耐油性優異、拉伸強度高，適合機械加工與化工環境；PVC（聚氯乙烯）手套成本較低，適合食品業、輕化工作業。兩者喬新針織均可大量批發供應。",
      },
    },
    {
      "@type": "Question",
      name: "電子廠或無塵室適合用哪種手套？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "電子廠和半導體廠建議使用尼龍手套或無塵室專用耗材，不易產生靜電與棉絮，避免污染精密元件。喬新針織設有無塵室耗材分類，歡迎洽詢。",
      },
    },
    {
      "@type": "Question",
      name: "手套批發最低訂購量是多少？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "最低訂購量依品項而異，歡迎來電 06-6900359 或透過線上詢價表單洽詢。客製規格（重量、尺寸、印刷）亦可接單，工廠直營、交期穩定。",
      },
    },
    {
      "@type": "Question",
      name: "喬新針織是什麼公司？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "喬新針織有限公司（品牌名：紅螞蟻手套）成立於 2003 年，位於台南市官田區，是台灣本土工作手套批發商，專營棉紗手套、NBR/PVC 膠手套、尼龍手套、白龍花龍手套及口罩、包裝材料等工安耗材，長期供應製造業、物流業、工程業企業客戶，全台配送。",
      },
    },
  ],
};
---

<Layout
  title="棉紗手套・工作手套・膠手套批發目錄｜紅螞蟻手套・喬新針織"
  description={productsDescription}
  keywords={["棉紗手套批發", "工作手套廠商", "NBR手套", "PVC手套", "尼龍手套", "沾膠手套", "口罩批發", "PE膜", "太空包", "台南手套", "工安耗材"]}
  canonical="/products"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ① 麵包屑 + 頁面標題 + 信任條 -->
  <div class="prd-outer">
    <nav class="prd-breadcrumb" aria-label="breadcrumb">
      <a href="/">首頁</a>
      <span class="prd-sep" aria-hidden="true">／</span>
      <span class="prd-cur">商品介紹</span>
    </nav>

    <div class="prd-head">
      <h1 class="prd-h1">工安耗材批發目錄｜工作手套・膠手套・口罩</h1>
      <p class="prd-sub">成立 2003 年・台南在地廠商直營・全台配送</p>

      <div class="prd-trust">
        <div class="trust-item">
          <div class="trust-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
          </div>
          <span><strong>台南在地製造</strong>・品質直營</span>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <span><strong>全台快速配送</strong>・大量現貨</span>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/>
            </svg>
          </div>
          <span><strong>客製規格接單</strong>・來樣訂製</span>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <span><strong>成立 2003 年</strong>・超過 20 年批發經驗</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ② 黏性分類導覽（hp-qnav 樣式） -->
  <div class="prd-qnav-wrap">
    <div class="prd-qnav-outer">
      <p class="prd-qnav-label">全部分類</p>
      <nav class="prd-qnav" id="catNav" aria-label="產品分類">
        {availableCategories.map(cat => (
          <a class="prd-qn-item" href={`#${cat.id}`} title={cat.name}>
            <div class="prd-qn-icon">
              {cat.id === 'cotton-gloves'        && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><line x1="3" y1="17" x2="21" y2="17" stroke-dasharray="2 1.5"/></svg>}
              {cat.id === 'rubber-gloves'        && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><path d="M2 19.5h20" stroke-width="2.5"/></svg>}
              {cat.id === 'nylon-gloves'         && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><line x1="2" y1="13.5" x2="22" y2="21.5" stroke-dasharray="2 2" stroke-width="1"/><line x1="2" y1="17.5" x2="15" y2="22" stroke-dasharray="2 2" stroke-width="1"/></svg>}
              {cat.id === 'white-dragon-gloves'  && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/></svg>}
              {cat.id === 'flower-dragon-gloves' && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><circle cx="7" cy="18.5" r="1.5"/><circle cx="12" cy="18.5" r="1.5"/><circle cx="17" cy="18.5" r="1.5"/></svg>}
              {cat.id === 'masks'                && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M3 11c0-2 2-3 5-4l4-1.5L16 7c3 1 5 2 5 4v3c0 3-4 5.5-9 5.5S3 17 3 14v-3z"/><path d="M7 13h10M8 16h8"/></svg>}
              {cat.id === 'packaging'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="M18.5 5.5l2-2M20.5 3.5l1 1-1.5 3"/></svg>}
              {cat.id === 'hardware'             && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94L5.83 19.83a2 2 0 01-2.83-2.83l7.94-7.94A6 6 0 0114.7 6.3z"/></svg>}
              {cat.id === 'bulk-bags'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M5 9h14v9.5c0 2-1.5 3-4 3H9c-2.5 0-4-1-4-3V9z"/><path d="M7 9V6M17 9V6M6 6h12"/><line x1="5" y1="14.5" x2="19" y2="14.5" stroke-dasharray="2 2"/></svg>}
              {cat.id === 'cleaning'             && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M9 3h6l1 8H8L9 3z"/><path d="M7 11v8a1 1 0 001 1h8a1 1 0 001-1v-8"/><path d="M10 15h4"/></svg>}
              {cat.id === 'special-gloves'       && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><path d="M12 15l.9 1.8 1.9.3-1.4 1.4.3 1.9-1.7-.9-1.7.9.3-1.9-1.4-1.4 1.9-.3z"/></svg>}
              {cat.id === 'traffic-safety'       && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M12 3L7 20h10L12 3z"/><path d="M8.5 14h7M9.5 17.5h5"/></svg>}
              {cat.id === 'cleanroom'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M12 3L4 6v5c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6l-8-3z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="7.5" y1="13" x2="16.5" y2="13"/><line x1="9" y1="16" x2="15" y2="16"/></svg>}
              {cat.id === 'others'               && <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>}
            </div>
            <span class="prd-qn-label">{cat.name}</span>
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- ③ 主內容 -->
  <div class="prd-outer">
    <main class="prd-main">

      <!-- URL 搜尋結果提示 -->
      <div id="search-result-banner" class="prd-banner prd-banner-info hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="prd-banner-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <span>搜尋「<strong id="search-query-display"></strong>」的結果：<span id="search-count" class="font-bold"></span> 項產品</span>
        <a href="/products" class="prd-banner-clear">清除</a>
      </div>
      <div id="no-results-banner" class="prd-banner prd-banner-warn hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="prd-banner-ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <span>找不到符合「<strong id="no-results-query"></strong>」的產品</span>
        <a href="/products" class="prd-banner-clear">查看全部</a>
      </div>

      <!-- 分類產品列表 -->
      {categories.map((cat) => {
        const catProducts = products.filter(
          (p) => p.category === cat.id && p.available !== false
        );
        if (catProducts.length === 0) return null;
        return (
          <section
            id={cat.id}
            class="prd-section category-section"
            data-category={cat.id}
          >
            <div class="prd-cat-hdr">
              <div>
                <h2 class="prd-cat-name">{cat.name}</h2>
                <p class="prd-cat-desc">{cat.description}</p>
              </div>
              <span class="prd-cat-cnt">{catProducts.length} 款</span>
            </div>

            <div class="prd-grid">
              {catProducts.map((p) => (
                <a
                  href={`/products/${p.id}`}
                  class="prd-card product-card"
                  data-product-id={p.id}
                  data-product-name={p.name}
                  data-product-description={p.description}
                  data-product-category={p.category}
                  data-product-tags={(p.tags || []).join(" ")}
                >
                  <div class="prd-card-img">
                    <img
                      src={`/${p.image}`}
                      alt={`${p.name}${p.size && p.size !== '-' ? ` ${p.size}` : ''} ${cat.name}批發 - 喬新針織`}
                      loading="lazy"
                      width="300"
                      height="300"
                    />
                  </div>
                  <div class="prd-card-body">
                    <div class="prd-card-title-row">
                      <span class="prd-card-name">{p.name}</span>
                      {p.size && p.size !== "-" && (
                        <span class="prd-size-badge">{p.size}</span>
                      )}
                    </div>
                    <p class="prd-card-desc">{p.description}</p>
                    <span class="prd-card-cta" aria-label={`了解 ${p.name} 規格與報價`}>了解規格 →</span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        );
      })}

      <!-- ④ FAQ 區塊（AEO / FAQPage schema） -->
      <p class="prd-brand-intro">
        喬新針織（紅螞蟻手套）自 2003 年起深耕台南，專業批發各式工作手套與工安耗材，
        涵蓋棉紗手套、NBR/PVC 膠手套、尼龍手套、白龍花龍手套等 14 大分類。
        工廠直營、品質穩定、重量足，長期供應製造業、物流業、工程業等企業客戶，全台配送。
      </p>
      <section class="prd-faq" aria-labelledby="faq-title">
        <h2 id="faq-title" class="prd-faq-title">常見問題</h2>

        <div class="prd-faq-list">
          <details class="prd-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="prd-faq-q" itemprop="name">棉紗手套幾兩才夠用？</summary>
            <div class="prd-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">一般工地搬運建議選 20 兩，重工場合可選 24 兩，含棉量高者更舒適耐用。喬新針織（紅螞蟻手套）提供多種重量規格，支援大量批發採購。</p>
            </div>
          </details>

          <details class="prd-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="prd-faq-q" itemprop="name">NBR 手套和 PVC 手套有什麼差別？</summary>
            <div class="prd-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">NBR（丁腈橡膠）手套耐油性優異、拉伸強度高，適合機械加工與化工環境；PVC（聚氯乙烯）手套成本較低，適合食品業、輕化工作業。兩者喬新針織均可大量批發供應。</p>
            </div>
          </details>

          <details class="prd-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="prd-faq-q" itemprop="name">電子廠或無塵室適合用哪種手套？</summary>
            <div class="prd-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">電子廠和半導體廠建議使用尼龍手套或無塵室專用耗材，不易產生靜電與棉絮，避免污染精密元件。喬新針織設有無塵室耗材分類，歡迎來電 06-6900359 洽詢。</p>
            </div>
          </details>

          <details class="prd-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="prd-faq-q" itemprop="name">手套批發最低訂購量是多少？</summary>
            <div class="prd-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">最低訂購量依品項而異，歡迎來電 06-6900359 或透過線上詢價表單洽詢。客製規格（重量、尺寸、印刷）亦可接單，工廠直營、交期穩定。</p>
            </div>
          </details>

          <details class="prd-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="prd-faq-q" itemprop="name">喬新針織是什麼公司？</summary>
            <div class="prd-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">喬新針織有限公司（品牌名：紅螞蟻手套）成立於 2003 年，位於台南市官田區，是台灣本土工作手套批發商，專營棉紗手套、NBR/PVC 膠手套、尼龍手套、白龍花龍手套及口罩、包裝材料等工安耗材，長期供應製造業、物流業、工程業企業客戶，全台配送。</p>
            </div>
          </details>
        </div>
      </section>

      <!-- ⑤ 詢價 CTA 橫幅 -->
      <div class="prd-cta-banner">
        <div class="prd-cta-text">
          <h3>大量採購享優惠・客製規格歡迎詢問</h3>
          <p>工廠直營・棉紗手套・膠手套・口罩・包裝材料・全品項供應</p>
        </div>
        <div class="prd-cta-actions">
          <a href={`tel:${company.contact.phone}`} class="prd-cta-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:16px;height:16px;flex-shrink:0;">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.08 1.19 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
            </svg>
            {company.contact.phone}
          </a>
          <a href="/contact" class="prd-cta-btn">立即詢價 →</a>
        </div>
      </div>

    </main>
  </div>

  <!-- ⑤ 回頂部按鈕 -->
  <button class="prd-btt" id="prdBtt" aria-label="回到頂部">↑</button>

</Layout>

<style>
  /* ── 設計 Token ── */
  :root {
    --prd-red:    #c0392b;
    --prd-orange: #FF6B35;
    --prd-td:     #4A90A4;
    --prd-teal:   #D4A574;
    --prd-cream:  #F7F6F3;
    --prd-white:  #ffffff;
    --prd-ink:    #1F2937;
    --prd-sub:    #6B7280;
    --prd-line:   #E6E4DE;
    --prd-chip:   color-mix(in srgb, #4A90A4 12%, white);
    --prd-px:     clamp(20px, 5vw, 64px);
  }

  /* ── 容器 ── */
  .prd-outer {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--prd-px);
  }

  /* ── ① 麵包屑 ── */
  .prd-breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--prd-sub);
    padding-top: 20px; margin-bottom: 10px;
  }
  .prd-breadcrumb a { text-decoration: none; color: var(--prd-sub); transition: color .15s; }
  .prd-breadcrumb a:hover { color: var(--prd-red); }
  .prd-sep  { opacity: .4; }
  .prd-cur  { color: var(--prd-ink); font-weight: 600; }

  /* ── 頁面標題 ── */
  .prd-head { padding-bottom: 20px; }
  .prd-h1 {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 900; color: var(--prd-ink); margin-bottom: 4px;
  }
  .prd-sub { font-size: 13px; color: var(--prd-sub); margin-bottom: 10px; }

  /* 品牌簡介段落（GEO 引用錨點） */
  .prd-brand-intro {
    font-size: 14px; line-height: 1.75; color: var(--prd-sub);
    background: var(--prd-white); border: 1px solid var(--prd-line);
    border-left: 3px solid var(--prd-td);
    border-radius: 0 8px 8px 0;
    padding: 12px 16px; margin-bottom: 16px;
  }

  /* ── 信任條 ── */
  .prd-trust {
    display: flex; gap: clamp(12px, 3vw, 28px); flex-wrap: wrap;
    padding: 12px 16px;
    background: var(--prd-white); border: 1px solid var(--prd-line); border-radius: 10px;
  }
  .trust-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--prd-sub);
  }
  .trust-icon {
    width: 28px; height: 28px; border-radius: 50%; background: var(--prd-chip);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .trust-icon svg { width: 14px; height: 14px; stroke: var(--prd-td); }
  .trust-item strong { color: var(--prd-ink); font-weight: 700; }

  /* ── ② 黏性分類導覽 ── */
  .prd-qnav-wrap {
    background: var(--prd-white);
    border-bottom: 1px solid var(--prd-line);
    position: sticky;
    top: 64px;
    z-index: 90;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
  }
  .prd-qnav-outer {
    max-width: 1280px; margin-inline: auto;
    padding-inline: var(--prd-px);
    padding-block: 12px 8px;
  }
  .prd-qnav-label {
    font-size: 11px; font-weight: 700; color: var(--prd-sub);
    margin: 0 0 8px; letter-spacing: .05em;
  }
  .prd-qnav {
    display: flex; gap: clamp(12px, 2.5vw, 20px);
    overflow-x: auto; padding-bottom: 4px;
    scrollbar-width: none; scroll-snap-type: x proximity;
  }
  .prd-qnav::-webkit-scrollbar { display: none; }

  /* 手機右側漸層暗示可滑（不覆蓋 sticky） */
  @media (max-width: 1023px) {
    .prd-qnav-wrap::after {
      content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 48px;
      background: linear-gradient(to right, transparent, #fff);
      pointer-events: none; z-index: 1;
    }
  }

  .prd-qn-item {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center;
    gap: 5px; width: clamp(48px, 6.5vw, 64px);
    text-decoration: none; color: var(--prd-ink);
    scroll-snap-align: start; transition: color .15s;
  }
  .prd-qn-icon {
    width: clamp(38px, 5.5vw, 50px); height: clamp(38px, 5.5vw, 50px);
    border-radius: 50%; background: var(--prd-chip);
    display: flex; align-items: center; justify-content: center;
    transition: background .18s, box-shadow .18s;
  }
  .prd-qn-item:hover .prd-qn-icon {
    background: color-mix(in srgb, var(--prd-td) 22%, white);
  }
  .prd-qn-icon svg {
    width: 46%; height: 46%;
    stroke: var(--prd-td); fill: none;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .prd-qn-label {
    font-size: clamp(9px, 1vw, 11px); text-align: center;
    white-space: nowrap; line-height: 1.3; color: var(--prd-sub); transition: color .15s;
  }
  /* Active 狀態 */
  .prd-qn-item.active .prd-qn-icon {
    background: color-mix(in srgb, var(--prd-red) 12%, white);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--prd-red) 28%, white);
  }
  .prd-qn-item.active .prd-qn-icon svg { stroke: var(--prd-red); }
  .prd-qn-item.active .prd-qn-label { color: var(--prd-red); font-weight: 700; }

  /* 桌機：14 欄 grid */
  @media (min-width: 1024px) {
    .prd-qnav-wrap { position: sticky; }
    .prd-qnav-wrap::after { display: none; }
    .prd-qnav {
      display: grid; grid-template-columns: repeat(14, 1fr);
      overflow-x: visible; padding-bottom: 0; gap: 4px;
    }
    .prd-qn-item { width: auto; }
  }

  /* ── ③ 主內容 ── */
  .prd-main { padding: 28px 0 64px; }

  /* 搜尋提示 banner */
  .prd-banner {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px; border-radius: 10px;
    font-size: 13px; margin-bottom: 20px;
  }
  .prd-banner.hidden { display: none; }
  .prd-banner-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
  .prd-banner-warn { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
  .prd-banner-ico { width: 16px; height: 16px; flex-shrink: 0; }
  .prd-banner-clear {
    margin-left: auto; font-size: 12px; font-weight: 700;
    text-decoration: none; color: inherit; opacity: .7;
    padding: 2px 8px; border-radius: 6px; border: 1px solid currentColor;
    white-space: nowrap;
  }
  .prd-banner-clear:hover { opacity: 1; }

  /* 分類 Section */
  .prd-section { margin-bottom: 52px; scroll-margin-top: 148px; }

  /* 分類標題：品牌紅左邊框 */
  .prd-cat-hdr {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
    padding-left: 14px;
    border-left: 4px solid var(--prd-red);
  }
  .prd-cat-name { font-size: 19px; font-weight: 800; color: var(--prd-ink); line-height: 1.2; }
  .prd-cat-desc { font-size: 12px; color: var(--prd-sub); margin-top: 2px; }
  .prd-cat-cnt {
    margin-left: auto; flex-shrink: 0;
    background: var(--prd-line); color: var(--prd-sub);
    border-radius: 999px; padding: 2px 12px;
    font-size: 11px; font-weight: 700;
  }

  /* 產品 Grid — Version A（固定斷點） */
  .prd-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  @media (min-width: 768px) {
    .prd-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
  }

  /* 產品卡片 */
  .prd-card {
    background: var(--prd-white); border: 1px solid var(--prd-line);
    border-radius: 12px; overflow: hidden;
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column;
    transition: transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .18s;
  }
  .prd-card:hover {
    transform: scale(.97);
    box-shadow: 0 2px 12px rgba(0,0,0,.08);
  }
  .prd-card-img {
    aspect-ratio: 1 / 1; background: #F3F4F6; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .prd-card-img img {
    width: 100%; height: 100%; object-fit: contain; padding: 16px;
    transition: transform .3s ease;
  }
  .prd-card:hover .prd-card-img img { transform: scale(1.04); }

  .prd-card-body { padding: 12px 14px 14px; display: flex; flex-direction: column; flex: 1; }
  .prd-card-title-row {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 8px; margin-bottom: 5px;
  }
  .prd-card-name { font-size: 14px; font-weight: 700; color: var(--prd-ink); line-height: 1.3; }
  .prd-size-badge {
    background: var(--prd-line); color: var(--prd-sub);
    border-radius: 6px; padding: 2px 7px;
    font-size: 10px; font-weight: 600; white-space: nowrap; flex-shrink: 0; margin-top: 2px;
  }
  .prd-card-desc {
    font-size: 12px; color: var(--prd-sub); line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; flex: 1; margin-bottom: 12px;
  }
  .prd-card-cta {
    display: inline-flex; align-items: center; gap: 4px;
    background: var(--prd-orange); color: #fff;
    border-radius: 8px; padding: 7px 14px;
    font-size: 12px; font-weight: 700;
    text-decoration: none; align-self: flex-start; transition: opacity .15s;
  }
  .prd-card:hover .prd-card-cta { opacity: .88; }

  /* 手機版簡化卡片 */
  @media (max-width: 767px) {
    .prd-card-body    { padding: 8px 10px 10px; }
    .prd-card-name    { font-size: 12px; }
    .prd-card-desc    { display: none; }
    .prd-card-img img { padding: 8px; }
    .prd-card-cta {
      background: transparent; color: var(--prd-td);
      padding: 0; font-size: 11px;
    }
  }

  /* ── ④ 詢價 CTA 橫幅 ── */
  .prd-cta-banner {
    margin-top: 52px;
    background: linear-gradient(135deg, var(--prd-td) 0%, color-mix(in srgb, var(--prd-td) 65%, var(--prd-teal)) 100%);
    border-radius: 16px;
    padding: clamp(24px, 4vw, 40px) clamp(20px, 5vw, 52px);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 20px; color: #fff;
  }
  .prd-cta-text h3 { font-size: clamp(16px, 2.5vw, 22px); font-weight: 900; margin-bottom: 4px; }
  .prd-cta-text p  { font-size: 13px; opacity: .85; }
  .prd-cta-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .prd-cta-phone {
    display: flex; align-items: center; gap: 6px;
    font-size: clamp(15px, 2vw, 19px); font-weight: 900;
    letter-spacing: .04em; color: #fff; text-decoration: none; white-space: nowrap;
  }
  .prd-cta-btn {
    background: var(--prd-orange); color: #fff; border: none;
    border-radius: 999px; padding: 10px 24px;
    font-size: 14px; font-weight: 700; text-decoration: none;
    white-space: nowrap; transition: opacity .15s;
  }
  .prd-cta-btn:hover { opacity: .88; }

  /* ── FAQ 區塊 ── */
  .prd-faq { margin-bottom: 48px; }
  .prd-faq-title {
    font-size: 18px; font-weight: 800; color: var(--prd-ink);
    padding-left: 14px; border-left: 4px solid var(--prd-td);
    margin-bottom: 16px;
  }
  .prd-faq-list { display: flex; flex-direction: column; gap: 8px; }
  .prd-faq-item {
    background: var(--prd-white); border: 1px solid var(--prd-line);
    border-radius: 10px; overflow: hidden;
  }
  .prd-faq-item[open] { border-color: color-mix(in srgb, var(--prd-td) 30%, var(--prd-line)); }
  .prd-faq-q {
    list-style: none; cursor: pointer;
    padding: 14px 18px; font-size: 14px; font-weight: 700; color: var(--prd-ink);
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    user-select: none; transition: background .15s;
  }
  .prd-faq-q::-webkit-details-marker { display: none; }
  .prd-faq-q::after {
    content: '+'; font-size: 20px; font-weight: 400; color: var(--prd-td);
    flex-shrink: 0; transition: transform .2s;
  }
  .prd-faq-item[open] .prd-faq-q { background: var(--prd-chip); }
  .prd-faq-item[open] .prd-faq-q::after { content: '−'; }
  .prd-faq-q:hover { background: var(--prd-cream); }
  .prd-faq-a {
    padding: 0 18px 16px; font-size: 13px; line-height: 1.8; color: var(--prd-sub);
  }

  /* ── ⑥ 回頂部按鈕 ── */
  .prd-btt {
    position: fixed; bottom: 28px; right: 24px; z-index: 200;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--prd-ink); color: #fff; border: none;
    font-size: 18px; cursor: pointer;
    box-shadow: 0 4px 14px rgba(0,0,0,.22);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: translateY(12px);
    transition: opacity .25s, transform .25s, background .15s;
    pointer-events: none;
  }
  .prd-btt.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .prd-btt:hover { background: var(--prd-red); }
</style>

<script>
  // ── qnav Active 狀態（IntersectionObserver） ──
  const sections  = document.querySelectorAll<HTMLElement>('.prd-section');
  const navLinks  = document.querySelectorAll<HTMLAnchorElement>('#catNav .prd-qn-item');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = (entry.target as HTMLElement).id;
      navLinks.forEach(l => l.classList.remove('active'));
      const active = document.querySelector<HTMLAnchorElement>(`#catNav a[href="#${id}"]`);
      if (active) {
        active.classList.add('active');
        active.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    });
  }, { rootMargin: '-15% 0px -60% 0px', threshold: 0 });

  sections.forEach(s => observer.observe(s));

  navLinks.forEach(link => {
    link.addEventListener('click', function () {
      navLinks.forEach(l => l.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // ── 回頂部按鈕 ──
  const btt = document.getElementById('prdBtt');
  window.addEventListener('scroll', () => {
    btt?.classList.toggle('visible', window.scrollY > 320);
  }, { passive: true });
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── URL 搜尋參數處理（?q=...） ──
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q');
    if (!query) return;

    const searchQuery = query.trim().toLowerCase();
    const resultBanner   = document.getElementById('search-result-banner');
    const noResultBanner = document.getElementById('no-results-banner');
    const queryDisplay   = document.getElementById('search-query-display');
    const searchCount    = document.getElementById('search-count');
    const noResultsQuery = document.getElementById('no-results-query');
    const productCards   = document.querySelectorAll<HTMLElement>('.product-card');
    const catSections    = document.querySelectorAll<HTMLElement>('.category-section');

    let matchCount = 0;
    const matchingCats = new Set<string>();

    productCards.forEach(card => {
      const name  = (card.dataset.productName        || '').toLowerCase();
      const desc  = (card.dataset.productDescription || '').toLowerCase();
      const cat   = (card.dataset.productCategory    || '').toLowerCase();
      const tags  = (card.dataset.productTags        || '').toLowerCase();
      const match = name.includes(searchQuery) || desc.includes(searchQuery)
                 || cat.includes(searchQuery)  || tags.includes(searchQuery);
      if (match) { matchCount++; matchingCats.add(card.dataset.productCategory!); }
      else card.classList.add('hidden');
    });

    catSections.forEach(sec => {
      if (!matchingCats.has(sec.dataset.category!)) sec.classList.add('hidden');
    });

    if (matchCount > 0) {
      resultBanner?.classList.remove('hidden');
      if (queryDisplay) queryDisplay.textContent = query;
      if (searchCount)  searchCount.textContent  = String(matchCount);
    } else {
      noResultBanner?.classList.remove('hidden');
      if (noResultsQuery) noResultsQuery.textContent = query;
    }
  });
</script>
