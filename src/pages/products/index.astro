---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";
import categories from "../../data/categories.json";
import products from "../../data/products.json";
import seo from "../../data/seo.json";
---

<Layout
    title="商品介紹"
    description={`${company.name}提供多樣化的工作手套與防護用品，包括棉紗手套、尼龍手套、膠手套、口罩、包裝材料等，品質優良、價格合宜。`}
    keywords={["工作手套", "棉紗手套", "尼龍手套", "防護用品", "口罩", "膠帶"]}
    canonical="/products"
>
    <div class="drawer lg:drawer-open">
        <input id="my-drawer-2" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex flex-col p-4 md:p-10">
            <!-- Page content -->
            <div class="flex justify-between items-center mb-8">
                <h1 class="text-3xl font-bold">產品介紹</h1>
                <label
                    for="my-drawer-2"
                    class="btn btn-primary drawer-button lg:hidden"
                    >分類選單</label
                >
            </div>

            <!-- 搜尋結果提示 -->
            <div id="search-result-banner" class="hidden mb-6">
                <div class="alert alert-info shadow-lg">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="stroke-current shrink-0 h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path>
                    </svg>
                    <div>
                        <span
                            >搜尋「<strong id="search-query-display"
                            ></strong>」的結果：</span
                        >
                        <span id="search-count" class="font-bold"></span> 項產品
                    </div>
                    <a href="/products" class="btn btn-sm btn-ghost">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-4 w-4 mr-1"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        清除搜尋
                    </a>
                </div>
            </div>

            <!-- 無搜尋結果提示 -->
            <div id="no-results-banner" class="hidden mb-6">
                <div class="alert alert-warning shadow-lg">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="stroke-current shrink-0 h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
                        ></path>
                    </svg>
                    <span
                        >找不到符合「<strong id="no-results-query"
                        ></strong>」的產品</span
                    >
                    <a href="/products" class="btn btn-sm btn-ghost"
                        >查看所有產品</a
                    >
                </div>
            </div>

            {
                categories.map((cat) => {
                    const catProducts = products.filter(
                        (p) => p.category === cat.id,
                    );
                    if (catProducts.length === 0) return null;

                    return (
                        <section
                            id={cat.id}
                            class="mb-16 scroll-mt-24 category-section"
                            data-category={cat.id}
                        >
                            <div class="flex items-center gap-4 mb-6 border-b pb-2 border-base-300">
                                <span class="text-4xl" aria-hidden="true">
                                    {cat.icon}
                                </span>
                                <div>
                                    <h2 class="text-2xl font-bold">
                                        {cat.name}
                                    </h2>
                                    <p class="text-gray-500 text-sm mt-1">
                                        {cat.description}
                                    </p>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                {catProducts.map((product) => (
                                    <a
                                        href={`/products/${product.id}`}
                                        class="card bg-base-100 shadow-lg hover:shadow-xl transition-all duration-300 border border-base-200 group hover:-translate-y-1 product-card"
                                        data-product-id={product.id}
                                        data-product-name={product.name}
                                        data-product-description={
                                            product.description
                                        }
                                        data-product-category={product.category}
                                        data-product-tags={(
                                            product.tags || []
                                        ).join(" ")}
                                    >
                                        <figure class="px-4 pt-4 relative bg-base-200/50 min-h-[200px] flex items-center justify-center overflow-hidden">
                                            <img
                                                src={`/${product.image}`}
                                                alt={`${product.name} - ${cat.name}`}
                                                class="rounded-xl h-48 object-contain group-hover:scale-105 transition-transform duration-300"
                                                loading="lazy"
                                                width="300"
                                                height="200"
                                            />
                                            <div class="badge badge-secondary absolute top-2 right-2">
                                                {cat.name}
                                            </div>
                                        </figure>
                                        <div class="card-body">
                                            <h3 class="card-title text-lg">
                                                {product.name}
                                                {product.size &&
                                                    product.size !== "-" && (
                                                        <div class="badge badge-outline text-xs">
                                                            {product.size}
                                                        </div>
                                                    )}
                                            </h3>
                                            <p class="text-sm text-gray-500 line-clamp-3">
                                                {product.description}
                                            </p>
                                            <div class="card-actions justify-end mt-4">
                                                <span class="btn btn-sm btn-primary group-hover:btn-secondary transition-colors">
                                                    查看詳情 →
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </section>
                    );
                })
            }
        </div>
        <div class="drawer-side z-40">
            <label
                for="my-drawer-2"
                aria-label="關閉側邊選單"
                class="drawer-overlay"></label>
            <nav aria-label="產品分類">
                <ul
                    class="menu p-4 w-80 min-h-full bg-base-200 text-base-content pt-20 lg:pt-4"
                >
                    <li class="menu-title text-lg mb-2 text-primary">
                        產品分類
                    </li>
                    {
                        categories.map((cat) => (
                            <li>
                                <a
                                    href={`#${cat.id}`}
                                    class="flex justify-between"
                                >
                                    <span>
                                        <span aria-hidden="true">
                                            {cat.icon}
                                        </span>{" "}
                                        {cat.name}
                                    </span>
                                    <span class="badge badge-sm">
                                        {
                                            products.filter(
                                                (p) => p.category === cat.id,
                                            ).length
                                        }
                                    </span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </div>
    </div>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const urlParams = new URLSearchParams(window.location.search);
        const query = urlParams.get("q");

        if (!query) return;

        const searchQuery = query.trim().toLowerCase();
        const searchResultBanner = document.getElementById(
            "search-result-banner",
        );
        const noResultsBanner = document.getElementById("no-results-banner");
        const searchQueryDisplay = document.getElementById(
            "search-query-display",
        );
        const searchCount = document.getElementById("search-count");
        const noResultsQuery = document.getElementById("no-results-query");
        const productCards = document.querySelectorAll(".product-card");
        const categorySections = document.querySelectorAll(".category-section");

        let matchCount = 0;
        const matchingCategories = new Set();

        // 過濾產品
        productCards.forEach((el) => {
            const card = el as HTMLElement;
            const name = (card.dataset.productName || "").toLowerCase();
            const description = (
                card.dataset.productDescription || ""
            ).toLowerCase();
            const category = (card.dataset.productCategory || "").toLowerCase();
            const tags = (card.dataset.productTags || "").toLowerCase();

            const matches =
                name.includes(searchQuery) ||
                description.includes(searchQuery) ||
                category.includes(searchQuery) ||
                tags.includes(searchQuery);

            if (matches) {
                matchCount++;
                matchingCategories.add(card.dataset.productCategory);
                card.classList.remove("hidden");
            } else {
                card.classList.add("hidden");
            }
        });

        // 隱藏沒有符合產品的分類區塊
        categorySections.forEach((el) => {
            const section = el as HTMLElement;
            const categoryId = section.dataset.category;
            if (!matchingCategories.has(categoryId)) {
                section.classList.add("hidden");
            }
        });

        // 顯示搜尋結果提示
        if (matchCount > 0) {
            if (searchResultBanner)
                searchResultBanner.classList.remove("hidden");
            if (searchQueryDisplay) searchQueryDisplay.textContent = query;
            if (searchCount) searchCount.textContent = matchCount.toString();
        } else {
            if (noResultsBanner) noResultsBanner.classList.remove("hidden");
            if (noResultsQuery) noResultsQuery.textContent = query;
        }
    });
</script>
