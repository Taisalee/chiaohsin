---
import Layout from "../layouts/Layout.astro";
import company from "../data/company.json";
import seo from "../data/seo.json";

const { map } = company.assets.images;

// 聯絡頁面 SEO 設定
const contactDescription = `聯絡${company.name} - 電話：${company.contact.phone}，地址：${company.address.full}。專業工作手套供應商，歡迎來電或來信洽詢。`;
const contactKeywords = [
  company.name,
  "聯絡我們",
  "工作手套",
  company.address.city,
  company.address.district,
];
---

<Layout
  title="聯絡我們"
  description={contactDescription}
  keywords={contactKeywords}
  canonical="/contact"
>
  <div class="bg-base-200 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold text-gray-900 mb-4">聯絡我們</h1>
        <p class="text-lg text-gray-600">
          歡迎隨時與我們聯繫，我們將竭誠為您服務
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- Contact Info (Left) -->
        <div class="card bg-base-100 shadow-md">
          <div class="card-body p-8 space-y-8">
            <!-- Address Section -->
            <div class="flex items-start gap-4">
              <div
                class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 text-lg mb-1">地址</h3>
                <p class="text-gray-600 mb-2">{company.address.full}</p>
                <a
                  href="https://maps.app.goo.gl/bfZzaDUa1xwVRUof9"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline text-sm flex items-center gap-1"
                >
                  開啟 Google 地圖
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Phone Section -->
            <div class="flex items-start gap-4">
              <div
                class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 text-lg mb-1">電話</h3>
                <a
                  href={`tel:${company.contact.phone}`}
                  class="block text-xl font-bold text-primary hover:underline mb-1"
                >
                  {company.contact.phone}
                </a>
                <p class="text-sm text-gray-500">傳真: {company.contact.fax}</p>
              </div>
            </div>

            <!-- Email Section -->
            <div class="flex items-start gap-4">
              <div
                class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 text-lg mb-1">電子郵件</h3>
                <a
                  href={`mailto:${company.contact.email}`}
                  class="text-gray-600 hover:text-primary transition-colors block mb-1"
                >
                  {company.contact.email}
                </a>
                <p class="text-sm text-gray-500">
                  聯絡人: {company.contact.contactPerson}
                </p>
              </div>
            </div>

            <!-- Hours Section -->
            <div class="flex items-start gap-4">
              <div
                class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-gray-900 text-lg mb-1">營業時間</h3>
                <p class="text-gray-600">週一至週五 08:00 - 17:00</p>
                <p class="text-sm text-gray-500 mt-1">週六、週日公休</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Map (Right) -->
        <div
          class="card bg-base-100 shadow-md h-full min-h-[500px] overflow-hidden"
        >
          <iframe
            src={`https://maps.google.com/maps?q=${company.address.coordinates.lat},${company.address.coordinates.lng}&hl=zh-TW&z=16&output=embed`}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full h-full"
            title="公司位置地圖"></iframe>
        </div>
      </div>
    </div>
  </div>
</Layout>
