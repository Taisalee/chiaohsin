---
import Layout from "../layouts/Layout.astro";
import company from "../data/company.json";
import seo from "../data/seo.json";

const { map } = company.assets.images;

// 聯絡頁面 SEO 設定
const contactDescription = `聯絡${company.name} - 電話：${company.contact.phone}，地址：${company.address.full}。專業工作手套供應商，歡迎來電或來信洽詢。`;
const contactKeywords = [
  company.name,
  "聯絡我們",
  "工作手套",
  company.address.city,
  company.address.district,
  ...seo.keywords.slice(0, 5),
];
---

<Layout
  title="聯絡我們"
  description={contactDescription}
  keywords={contactKeywords}
  canonical="/contact"
>
  <div class="bg-base-200 py-10">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold">聯絡我們</h1>
      <p class="py-4 text-xl">歡迎隨時與我們聯繫</p>
    </div>

    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-10">
      <!-- Info Card -->
      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <h2 class="card-title text-2xl mb-6 text-primary">公司資訊</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-3 rounded-full text-primary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold">地址</h3>
                <p class="text-lg">{company.address.full}</p>
                <div class="mt-2">
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${company.address.coordinates.lat},${company.address.coordinates.lng}`}
                    target="_blank"
                    class="btn btn-sm btn-outline"
                  >
                    開啟 Google 地圖
                  </a>
                </div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-3 rounded-full text-primary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold">電話</h3>
                <p class="text-lg">{company.contact.phone}</p>
                <p class="text-gray-500">傳真: {company.contact.fax}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-3 rounded-full text-primary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold">Email</h3>
                <a
                  href={`mailto:${company.contact.email}`}
                  class="link link-primary text-lg">{company.contact.email}</a
                >
                <p class="text-gray-500">
                  聯絡人: {company.contact.contactPerson}
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-3 rounded-full text-primary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
              </div>
              <div>
                <h3 class="font-bold">營業時間</h3>
                <p class="text-lg">週一至週五 08:00 - 17:00</p>
                <p class="text-gray-500">週六、週日公休</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Map Image -->
      <div class="card bg-base-100 shadow-xl overflow-hidden">
        <figure class="h-full relative">
          <!-- Using the static map image from data -->
          <img
            src={`/${map}`}
            alt="Location Map"
            class="w-full h-full object-cover min-h-[400px]"
          />
          <div class="absolute bottom-4 right-4 badge badge-lg">公司位置圖</div>
        </figure>
      </div>
    </div>
  </div>
</Layout>
