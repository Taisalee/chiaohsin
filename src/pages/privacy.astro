---
import Layout from "../layouts/Layout.astro";
import company from "../data/company.json";

const siteUrl = "https://chiaohsin.com.tw";
const pageDescription = "喬新針織隱私權政策：本網站未透過表單或追蹤工具蒐集任何個人資料，說明聯絡方式的資料流向。";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "隱私權政策", item: `${siteUrl}/privacy` },
  ],
};
---

<Layout
  title="隱私權政策"
  description={pageDescription}
  canonical="/privacy"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <div class="bg-base-200 py-12">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">隱私權政策</h1>
      <div class="card bg-base-100 shadow-md">
        <div class="card-body prose prose-sm max-w-none">
          <p>本網站（{company.website}）為靜態型錄網站，未設置任何線上表單、會員系統或第三方分析追蹤程式，不會透過本網站蒐集、儲存您的個人資料。</p>

          <h2>聯絡方式的資料流向</h2>
          <p>網站上的電話、LINE、Email 連結會將您導向對應的通訊軟體或電信服務（如 LINE、您的電子郵件信箱、電話撥號程式），實際的通話或訊息內容由該第三方服務業者處理，適用其各自的隱私權規範，不在本網站的蒐集範圍內。</p>

          <h2>網站代管服務</h2>
          <p>本網站透過第三方代管與內容傳遞服務（CDN）供應，這類服務可能因網站安全與效能維運需要，記錄基本的連線技術資訊（如 IP 位址、瀏覽器類型），此為業界標準做法，與本公司主動蒐集個資的行為無關。</p>

          <h2>聯絡我們</h2>
          <p>若您對本隱私權政策有任何疑問，歡迎透過電話 {company.contact.phone} 或 Email {company.contact.email} 與我們聯繫。</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
