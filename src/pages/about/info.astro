---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";

const infoDescription = `${company.name} - 公司基本資料與核心優勢。提供專業、透明且值得信賴的企業資訊。`;
const infoKeywords = [
  company.name,
  "公司資料",
  "基本資訊",
  "核心價值",
  "工作手套專家",
];

const features = [
  {
    title: "優選品質",
    description:
      "高品質生產標準，從材料篩選到成品檢驗，確保每一雙手套都能提供最佳防護性能。",
    icon: "/images/featureicon01.png",
    color: "bg-blue-500",
  },
  {
    title: "合理價格",
    description:
      "工廠直營模式，捨棄中間商利潤，將最實惠的批發價格直接回饋給長期支持我們的客戶。",
    icon: "/images/featureicon02.png",
    color: "bg-emerald-500",
  },
  {
    title: "重量足額",
    description:
      "誠信經營的核心，我們保證手套規格與描述完全相符，不偷工減料，實實在在的耐磨耐用。",
    icon: "/images/featureicon03.png",
    color: "bg-amber-500",
  },
  {
    title: "信賴夥伴",
    description:
      "深耕台灣多年，累積豐厚的產業口碑，是眾多專業技師與大型企業首選的長期防護夥伴。",
    icon: "/images/featureicon04.png",
    color: "bg-rose-500",
  },
];
---

<Layout
  title="公司資料"
  description={infoDescription}
  keywords={infoKeywords}
  canonical="/about/info"
>
  <!-- 精簡頁首 -->
  <header
    class="bg-gradient-to-r from-gray-900 via-gray-800 to-primary py-16 text-white text-center"
  >
    <div class="max-w-4xl mx-auto px-4">
      <nav
        class="flex justify-center items-center space-x-2 text-white/60 text-sm mb-6"
      >
        <a href="/" class="hover:text-white transition-colors">首頁</a>
        <span class="opacity-30">/</span>
        <a href="/about" class="hover:text-white transition-colors">關於我們</a>
        <span class="opacity-30">/</span>
        <span class="text-white">基本資料</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        公司<span class="text-primary-focus">基本資料</span>
      </h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto leading-relaxed">
        秉持專業、誠信、永續經營的態度，喬新為您提供最完整的企業背景與核心價值資訊。
      </p>
    </div>
  </header>

  <section class="py-20 bg-base-200/50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- 左側：公司資訊表 -->
        <div class="lg:col-span-8 space-y-8">
          <div
            class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 overflow-hidden border border-gray-100"
          >
            <div
              class="p-8 border-b border-gray-100 flex items-center justify-between bg-white"
            >
              <h2
                class="text-2xl font-black text-gray-900 flex items-center gap-3"
              >
                <span class="w-2 h-8 bg-primary rounded-full"></span>
                企業營運資訊
              </h2>
              <img
                src="/images/LOGO-03.png"
                alt="Logo"
                class="h-10 opacity-80"
              />
            </div>
            <div class="divide-y divide-gray-50">
              {
                [
                  { label: "公司名稱", value: company.name },
                  { label: "英文名稱", value: company.englishName },
                  { label: "營業地址", value: company.address.full },
                  {
                    label: "電子郵件",
                    value: company.contact.email,
                    link: `mailto:${company.contact.email}`,
                  },
                  {
                    label: "服務熱線",
                    value: company.contact.phone,
                    link: `tel:${company.contact.phone}`,
                  },
                  { label: "傳真號碼", value: company.contact.fax },
                  { label: "聯絡窗口", value: company.contact.contactPerson },
                  {
                    label: "主要產品",
                    value: company.services.products.join("、"),
                  },
                  { label: "服務地區", value: company.services.area },
                ].map((item) => (
                  <div class="grid grid-cols-1 md:grid-cols-4 p-6 hover:bg-gray-50/50 transition-colors group">
                    <div class="md:col-span-1 text-gray-400 font-bold text-sm tracking-wider uppercase flex items-center">
                      {item.label}
                    </div>
                    <div class="md:col-span-3 mt-1 md:mt-0">
                      {item.link ? (
                        <a
                          href={item.link}
                          class="text-primary font-black text-lg hover:underline decoration-2 underline-offset-4"
                        >
                          {item.value}
                        </a>
                      ) : (
                        <span class="text-gray-800 font-bold text-lg">
                          {item.value}
                        </span>
                      )}
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- 經營項目摘要 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div
              class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100"
            >
              <h3 class="font-black text-xl mb-4 flex items-center gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                  ></path>
                </svg>
                付款方式
              </h3>
              <div class="flex flex-wrap gap-2">
                {
                  company.services.payment.map((p) => (
                    <span class="px-4 py-2 bg-gray-100 text-gray-700 rounded-xl font-bold text-sm">
                      {p}
                    </span>
                  ))
                }
              </div>
            </div>
            <div
              class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100"
            >
              <h3 class="font-black text-xl mb-4 flex items-center gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                營業時間
              </h3>
              <p class="text-gray-600 font-medium">週一至週五 08:00 - 17:00</p>
              <p class="text-gray-400 text-sm mt-1">國定假日與週末公休</p>
            </div>
          </div>
        </div>

        <!-- 右側：核心優勢 (Refined Style 1 Features) -->
        <div class="lg:col-span-4 space-y-6">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-2xl font-black text-gray-900">核心優勢</h2>
            <div class="flex-grow h-px bg-gray-200"></div>
          </div>

          {
            features.map((feature) => (
              <div class="group relative bg-white p-6 rounded-[2rem] shadow-md border border-gray-100 hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-150 duration-700" />

                <div class="flex gap-6 items-start relative z-10">
                  <div class="w-16 h-16 rounded-2xl bg-gray-50 flex-shrink-0 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                    <img
                      src={feature.icon}
                      alt={feature.title}
                      class="w-10 h-10 object-contain"
                    />
                  </div>
                  <div class="space-y-2">
                    <h3 class="text-xl font-black text-gray-900 group-hover:text-primary transition-colors">
                      {feature.title}
                    </h3>
                    <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 group-hover:line-clamp-none">
                      {feature.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }

          <!-- 服務承諾 -->
          <div
            class="bg-primary text-white p-8 rounded-[2rem] shadow-xl shadow-primary/20 relative overflow-hidden mt-8"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="absolute bottom-[-20px] right-[-20px] h-32 w-32 text-white/10"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
              ></path>
            </svg>
            <h4 class="text-xl font-black mb-3">服務承諾</h4>
            <p class="text-white/80 text-sm leading-[1.8]">
              喬新針織始終堅持高品質標準，我們承諾所有出廠產品均經過嚴格品檢，確保客戶收到的每一批貨物都能符合最高期待。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* 微動畫效果 */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .grid > div {
    animation: fadeInUp 0.6s ease-out forwards;
  }
</style>
