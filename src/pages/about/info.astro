---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";
import seo from "../../data/seo.json";

// 基本資料頁面 SEO 設定
const infoDescription = `${company.name}基本資料 - 公司地址：${company.address.full}，聯絡電話：${company.contact.phone}，主要產品：${company.tagline}`;
const infoKeywords = [
  company.name,
  company.englishName,
  "公司資料",
  "基本資料",
];
---

<Layout
  title="基本資料"
  description={infoDescription}
  keywords={infoKeywords}
  canonical="/about/info"
>
  <div class="bg-base-200 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-8 text-center text-primary">基本資料</h1>

      <div
        class="card bg-base-100 shadow-xl overflow-hidden border border-base-200"
      >
        <div class="card-body p-0">
          <dl
            class="grid grid-cols-1 md:grid-cols-[180px_1fr] divide-y divide-base-200"
          >
            <!-- 公司名稱 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">公司名稱</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-lg font-bold tracking-wide text-gray-800">
                {company.name}
              </dd>
            </div>

            <!-- 英文名稱 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">英文名稱</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="font-mono text-gray-600">{company.englishName}</dd>
            </div>

            <!-- 主要產品 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">主要產品</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-gray-700">{company.tagline}</dd>
            </div>

            <!-- 服務項目 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">服務項目</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-gray-700">
                <div class="flex flex-wrap gap-x-1">
                  {
                    company.services.products.map((p, index) => (
                      <span>
                        {p}
                        {index < company.services.products.length - 1 && (
                          <span class="mx-1 text-gray-400">/</span>
                        )}
                      </span>
                    ))
                  }
                </div>
              </dd>
            </div>

            <!-- 配送方式 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">配送方式</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-gray-700">
                {company.services.delivery.join(" / ")}
              </dd>
            </div>

            <!-- 付款方式 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">付款方式</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-gray-700">
                {company.services.payment.join(" / ")}
              </dd>
            </div>

            <!-- 服務區域 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">服務區域</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd class="text-gray-700">{company.services.area}</dd>
            </div>

            <!-- 地址 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">地址</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd>
                <a
                  href="https://maps.app.goo.gl/bfZzaDUa1xwVRUof9"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link link-hover text-primary flex items-center gap-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                      clip-rule="evenodd"></path>
                  </svg>
                  {company.address.full}
                </a>
              </dd>
            </div>

            <!-- 聯絡電話 -->
            <div
              class="flex items-center px-6 py-4 bg-base-50 md:bg-base-200/30"
            >
              <dt class="font-medium text-gray-500">聯絡電話</dt>
            </div>
            <div class="flex items-center px-6 py-4">
              <dd>
                <a
                  href={`tel:${company.contact.phone}`}
                  class="btn bg-blue-600 border-none hover:bg-blue-700 text-white btn-sm gap-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                    ></path>
                  </svg>
                  {company.contact.phone}
                </a>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</Layout>
