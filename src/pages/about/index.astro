---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";

const LINE_ID = company.contact["LINE ID"];

const aboutDescription =
  "喬新針織．永立新國際：全台最值得信賴的防護手套與五金耗材供應商。深耕台南廿載，專業守護作業安全。";
const aboutKeywords = [
  ...(company.seo?.brandKeywords || []),
  "關於我們",
  "防護手套",
  "五金耗材",
  "棉紗手套",
  "工安防護",
];

const { banner } = company.assets.images;
---

<Layout
  title="關於我們 | 喬新針織．永立新國際"
  description={aboutDescription}
  keywords={aboutKeywords}
  canonical="/about/index2"
>
  <!-- ═══ 1. Hero ═══ -->
  <header
    class="relative h-[40vh] md:h-[50vh] flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={`/${banner}`}
        alt="關於我們 Banner"
        class="w-full h-full object-cover brightness-[0.35]"
      />
      <div
        class="absolute inset-0 bg-gradient-to-b from-primary/40 via-gray-900/40 to-base-100"
      >
      </div>
    </div>
    <div class="relative z-10 text-center px-4 w-full max-w-4xl mx-auto">
      <h1
        class="text-4xl md:text-6xl font-black text-white tracking-widest mb-6 drop-shadow-md"
      >
        喬新針織．永立新國際
      </h1>
      <p
        class="text-white/80 text-lg md:text-xl font-medium tracking-wide drop-shadow"
      >
        全台最值得信賴的防護手套與五金耗材供應商
      </p>
    </div>
  </header>

  <!-- ═══ 2. 簡介區塊 (Intro) ═══ -->
  <section class="py-20 md:py-28 bg-base-100 overflow-hidden relative">
    <div
      class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-bl-full flex-shrink-0"
    >
    </div>
    <div class="max-w-6xl mx-auto px-5 relative z-10">
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <!-- 左側文案 -->
        <div class="w-full md:w-1/3">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary font-bold text-sm tracking-widest uppercase mb-4"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"
            ></span>
            Company Profile
          </div>
          <h2
            class="text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight"
          >
            深耕台南二十餘載，<br />
            <span class="text-primary">專業守護作業安全</span>
          </h2>
        </div>

        <!-- 右側內容 -->
        <div class="w-full md:w-2/3">
          <div
            class="bg-white shadow-xl shadow-gray-100/50 border border-gray-100 rounded-3xl p-8 md:p-10 text-gray-600 text-lg leading-relaxed space-y-6"
          >
            <p>
              喬新針織有限公司 / 永立新國際有限公司 (Chiaohsin Knitting Co.,
              Ltd.) 成立於 2003
              年，總部位於台南市官田區。我們專精於各類針織工作手套與五金防護耗材的研發與供應，擁有超過
              20 年的產業實務經驗。
            </p>
            <p>
              身為台南在地的指標性廠商，我們以<strong
                class="text-primary tracking-wide"
                >「穩定供貨、規格透明、誠信經營」</strong
              >為核心價值，不僅深耕在地工業區，服務範疇更覆蓋全台地區，是各大企業、工廠、批發商及物流體系的首選合作夥伴。
            </p>
            <div
              class="mt-8 border-l-4 border-warning pl-6 py-2 bg-warning/5 rounded-r-lg"
            >
              <p class="text-gray-700 font-bold italic tracking-wide">
                「手套封口部分為車頭，不會脫落，更加緊實的包覆著您的雙手」
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 3. 核心產品與服務 ═══ -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-5">
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <!-- 左側卡片 (Desktop) / 下方卡片 (Mobile) -->
        <div
          class="w-full md:w-2/3 flex flex-col gap-8 order-last md:order-first"
        >
          <!-- Card 1 -->
          <div
            class="bg-white rounded-3xl p-8 md:p-10 shadow-lg shadow-gray-200/40 border-t-4 border-primary hover:-translate-y-2 transition-transform duration-300"
          >
            <div class="flex items-center gap-5 mb-6">
              <div
                class="w-14 h-14 bg-primary/10 text-primary rounded-2xl flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"
                  ></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-900">專業針織手套系列</h3>
            </div>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-primary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">核心產品：</strong>
                  <span class="text-gray-600"
                    >棉紗手套（堅持足重規格）、尼龍手套、白龍/花龍手套。</span
                  >
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-primary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">特殊機能：</strong>
                  <span class="text-gray-600"
                    >電子專用防靜電手套、工作用禦寒手套。</span
                  >
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 w-2 h-2 rounded-full bg-primary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">止滑強化：</strong>
                  <span class="text-gray-600"
                    >沾膠手套、點膠手套、日常與居家適用之洗澡手套。</span
                  >
                </div>
              </li>
            </ul>
          </div>

          <!-- Card 2 -->
          <div
            class="bg-white rounded-3xl p-8 md:p-10 shadow-lg shadow-gray-200/40 border-t-4 border-secondary hover:-translate-y-2 transition-transform duration-300"
          >
            <div class="flex items-center gap-5 mb-6">
              <div
                class="w-14 h-14 bg-secondary/10 text-secondary rounded-2xl flex items-center justify-center flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-900">
                五金與包裝防護耗材
              </h3>
            </div>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 w-2 h-2 rounded-full bg-secondary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">工業包裝：</strong>
                  <span class="text-gray-600"
                    >高強度 PE 伸縮膜、大容量太空袋。</span
                  >
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 w-2 h-2 rounded-full bg-secondary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">呼吸防護：</strong>
                  <span class="text-gray-600"
                    >活性碳口罩、各類拋棄式防護口罩。</span
                  >
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 w-2 h-2 rounded-full bg-secondary flex-shrink-0"
                ></span>
                <div>
                  <strong class="text-gray-800">耗材配件：</strong>
                  <span class="text-gray-600"
                    >工業級砂輪片、膠帶及各式常用五金雜貨。</span
                  >
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- 右側文案 (Desktop) / 上方文案 (Mobile) -->
        <div class="w-full md:w-1/3 order-first md:order-last">
          <div
            class="inline-flex items-center gap-2 text-secondary font-bold tracking-widest text-xs uppercase bg-secondary/10 px-3 py-1.5 rounded-full mb-4"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-secondary inline-block"
            ></span>
            Our Products
          </div>
          <h2
            class="text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight"
          >
            核心產品與服務<br />
            <span class="text-secondary text-2xl md:text-3xl mt-2 block"
              >一站式防護方案</span
            >
          </h2>
          <p class="text-gray-500 leading-relaxed">
            我們提供多元且規格齊全的產品線，確保每一位勞動者在不同作業環境下都能獲得最合適的保護。
          </p>
        </div>
      </div>
    </div>
  </section>

<!-- ═══ 4. 核心競爭力 ═══ -->
<section class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <!-- 左側文案 -->
      <div class="w-full md:w-1/3">
        <div
          class="inline-flex items-center gap-2 text-accent font-bold tracking-widest text-xs uppercase bg-accent/10 px-3 py-1.5 rounded-full mb-4"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
          Why Choose Us
        </div>
        <h2
          class="text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight"
        >
          為什麼選擇我們？<br />
          <span class="text-primary">三大核心競爭力</span>
        </h2>
        <p class="text-gray-500 leading-relaxed">
          長年深耕在地市場，了解勞動者需求，喬新/永立新給您最實在的承諾。
        </p>
      </div>

      <!-- 右側項目 -->
      <div class="w-full md:w-2/3 space-y-6">
        <!-- Item 1 -->
        <div
          class="flex gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100/80 hover:bg-white hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all group"
        >
          <div
            class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center flex-shrink-0 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300"
          >
            <span class="text-2xl font-black">1</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">
              品質穩定，足重承諾
            </h3>
            <p class="text-gray-600 leading-relaxed">
              我們深知手套耐用度對作業效率的重要性。喬新堅持「規格不縮水、重量足」，確保每批產品均具備高耐磨性與舒適度。
            </p>
          </div>
        </div>

        <!-- Item 2 -->
        <div
          class="flex gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100/80 hover:bg-white hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all group"
        >
          <div
            class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center flex-shrink-0 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300"
          >
            <span class="text-2xl font-black">2</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">
              台南在地服務，全國高效配送
            </h3>
            <p class="text-gray-600 leading-relaxed">
              憑藉在地的地理優勢與穩健的倉儲管理，我們為台南及鄰近地區提供現貨快速親取服務；針對全國客戶，則建立完善的宅配與物流體系，確保供貨不間斷。
            </p>
          </div>
        </div>

        <!-- Item 3 -->
        <div
          class="flex gap-5 p-6 rounded-2xl bg-gray-50 border border-gray-100/80 hover:bg-white hover:shadow-xl hover:shadow-primary/5 hover:border-primary/20 transition-all group"
        >
          <div
            class="w-14 h-14 bg-white rounded-xl shadow-sm flex items-center justify-center flex-shrink-0 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300"
          >
            <span class="text-2xl font-black">3</span>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">
              靈活交易，價格具競爭力
            </h3>
            <p class="text-gray-600 leading-relaxed">
              長期服務企業採購與大量批發客戶，我們提供合理的批發價格與多元支付方式（含電匯、貨到付款等），大幅簡化採購流程。
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ 5. 聯絡資訊區塊 ═══ -->
<section class="relative bg-gray-900 text-white">
  <div class="flex flex-col lg:flex-row min-h-[520px]">
    <!-- 左側：文字內容 -->
    <div
      class="lg:w-3/5 flex items-center py-8 lg:py-10 px-6 md:px-8 lg:px-10 order-2"
    >
      <div class="w-full">
        <h2 class="text-3xl md:text-5xl font-black mb-2">
          即刻諮詢專屬防護方案
        </h2>
        <p class="text-white/60 text-lg mb-5">
          喬新/永立新國際誠摯歡迎全台企業、工地負責人與經銷商洽詢合作，我們將由專人為您提供最精確的產品建議。
        </p>

        <div class="space-y-3 font-medium">
          <!-- 聯絡窗口 & LINE -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-3 border-t border-white/10">
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  聯絡窗口
                </p>
                <p class="text-xl font-bold">
                  {company.contact.contactPerson || "王小姐"}
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0"
                style="background-color:#06C755;"
              >
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="white"
                  ><path
                    d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  LINE 好友
                </p>
                <a
                  href={`https://line.me/ti/p/~${LINE_ID}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-lg font-bold hover:opacity-80 transition-opacity"
                  style="color:#06C755;"
                >
                  {LINE_ID}
                </a>
              </div>
            </div>
          </div>

          <!-- 服務專線 & 傳真 -->
          <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-3 border-t border-white/10"
          >
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  服務專線
                </p>
                <a
                  href={`tel:${company.contact.phone}`}
                  class="text-xl font-bold hover:text-primary transition-colors"
                >
                  {company.contact.phone}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  傳真
                </p>
                <p class="text-xl font-bold text-white/90">
                  {company.contact.fax}
                </p>
              </div>
            </div>
          </div>

          <!-- Email & 營業時間 -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-3 border-t border-white/10">
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  電子郵件
                </p>
                <a
                  href={`mailto:${company.contact.email}`}
                  class="text-lg text-white/90 hover:text-primary transition-colors"
                >
                  {company.contact.email}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  營業時間
                </p>
                <p class="text-lg text-white/90">週一至週五　08:00 – 17:00</p>
                <p class="text-white/40 text-xs mt-0.5">週六日・國定假日公休</p>
              </div>
            </div>
          </div>

          <!-- 地址 -->
          <div class="flex items-start gap-4 pt-3 border-t border-white/10">
            <div
              class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
              >
            </div>
            <div>
              <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                營業地址
              </p>
              <p class="text-lg text-white/90">{company.address.full}</p>
            </div>
          </div>

          <!-- 服務區域 & 支援付款 -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-3 border-t border-white/10">
            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"
                  ></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  服務區域
                </p>
                <p class="text-lg text-white/90">
                  台灣全境配送 / 台南地區歡迎親取
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-primary flex-shrink-0"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="text-white/40 text-sm mb-1 uppercase tracking-wider">
                  支援付款
                </p>
                <p class="text-lg text-white/90">
                  現金、ATM 轉帳、貨到付款、電匯
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 右側：Google 地圖 -->
    <div
      class="lg:w-2/5 relative order-1 h-[360px] lg:h-auto border-t lg:border-t-0 lg:border-r border-gray-800"
    >
      <iframe
        src={`https://maps.google.com/maps?q=${company.address.coordinates.lat},${company.address.coordinates.lng}&hl=zh-TW&z=15&output=embed`}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0 w-full h-full"
        title="公司位置地圖"></iframe>
    </div>
  </div>
</section>
</Layout>
