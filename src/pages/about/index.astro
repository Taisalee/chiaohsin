---
import Layout from "../../layouts/Layout.astro";
import company from "../../data/company.json";
import seo from "../../data/seo.json";

const LINE_ID = company.contact["LINE ID"];
const siteUrl = "https://www.chiaohsin.com.tw";

const aboutDescription =
  "喬新針織．永立新國際：全台最值得信賴的防護手套與五金耗材供應商。深耕台南廿載，專業守護作業安全。";
const aboutKeywords = [
  ...seo.brandKeywords,
  "關於我們",
  "防護手套",
  "五金耗材",
  "棉紗手套",
  "工安防護",
];

const { banner } = company.assets.images;

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${siteUrl}/about`,
  name: `關於${company.shortName}`,
  url: `${siteUrl}/about`,
  description: aboutDescription,
  mainEntity: {
    "@id": `${siteUrl}/#organization`,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "關於我們", item: `${siteUrl}/about` },
  ],
};

const faqs = [
  {
    q: "喬新針織／紅螞蟻手套是什麼時候成立的？",
    a: `喬新針織有限公司（永立新國際有限公司）成立於 ${company.foundingYear} 年，總部位於${company.address.city}${company.address.district}，至今已有超過 20 年的針織手套與五金耗材產業實務經驗。`,
  },
  {
    q: "紅螞蟻手套和喬新針織是同一家公司嗎？",
    a: "是的。「紅螞蟻手套」是喬新針織旗下的產品品牌，「魚得水」則是喬新針織旗下的另一個品牌，兩者皆隸屬喬新針織有限公司，市面上所見紅螞蟻手套系列產品皆由喬新針織有限公司製造供應。",
  },
  {
    q: "主要供應哪些產品？",
    a: "以針織工作手套為主力，包含棉紗手套、尼龍手套、白龍/花龍手套、電子專用防靜電手套等；同時供應活性碳口罩、PE 伸縮膜、太空袋、砂輪片、膠帶等五金與包裝防護耗材。",
  },
  {
    q: "服務範圍涵蓋全台灣嗎？",
    a: "是的，喬新針織提供全台配送服務，台南在地客戶也歡迎親自取貨；長期服務各大企業、工廠、批發商與物流體系客戶。",
  },
  {
    q: "支援哪些付款方式？",
    a: "支援現金、ATM 轉帳、貨到付款、電匯等多元付款方式，簡化企業與批發客戶的採購流程。",
  },
  {
    q: "營業時間與聯絡方式？",
    a: `營業時間為週一至週六 08:00–18:00（週日、國定假日公休）。可撥打服務專線 ${company.contact.phone} 或加入官方 LINE（ID：${company.contact["LINE ID"]}）詢價。`,
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const products = [
  {
    color: "td",
    title: "專業針織手套系列",
    items: [
      {
        label: "核心產品",
        parts: [
          { text: "棉紗手套", href: "/products#cotton-gloves" },
          { text: "（堅持足重規格）、" },
          { text: "尼龍手套", href: "/products#nylon-gloves" },
          { text: "、" },
          { text: "白龍", href: "/products#white-dragon-gloves" },
          { text: "/" },
          { text: "花龍手套", href: "/products#flower-dragon-gloves" },
          { text: "。" },
        ],
      },
      {
        label: "特殊機能",
        parts: [
          { text: "電子專用防靜電手套、工作用禦寒手套", href: "/products#special-gloves" },
          { text: "。" },
        ],
      },
      {
        label: "止滑強化",
        parts: [
          { text: "沾膠手套、點膠手套", href: "/products#rubber-gloves" },
          { text: "、日常與居家適用之" },
          { text: "洗澡手套", href: "/products#special-gloves" },
          { text: "。" },
        ],
      },
    ],
  },
  {
    color: "teal",
    title: "五金與包裝防護耗材",
    items: [
      {
        label: "工業包裝",
        parts: [
          { text: "高強度 PE 伸縮膜", href: "/products#packaging" },
          { text: "、" },
          { text: "大容量太空袋", href: "/products#bulk-bags" },
          { text: "。" },
        ],
      },
      {
        label: "呼吸防護",
        parts: [
          { text: "活性碳口罩、各類拋棄式防護口罩", href: "/products#masks" },
          { text: "。" },
        ],
      },
      {
        label: "耗材配件",
        parts: [
          { text: "工業級砂輪片", href: "/products#hardware" },
          { text: "、" },
          { text: "膠帶", href: "/products#packaging" },
          { text: "及各式常用" },
          { text: "五金雜貨", href: "/products#hardware" },
          { text: "。" },
        ],
      },
    ],
  },
];

const strengths = [
  { n: "1", title: "品質穩定，足重承諾", desc: "我們深知手套耐用度對作業效率的重要性。喬新堅持「規格不縮水、重量足」，確保每批產品均具備高耐磨性與舒適度。" },
  { n: "2", title: "台南在地服務，全國高效配送", desc: "憑藉在地的地理優勢與穩健的倉儲管理，我們為台南及鄰近地區提供現貨快速親取服務；針對全國客戶，則建立完善的宅配與物流體系，確保供貨不間斷。" },
  { n: "3", title: "靈活交易，價格具競爭力", desc: "長期服務企業採購與大量批發客戶，我們提供合理的批發價格與多元支付方式（含電匯、貨到付款等），大幅簡化採購流程。" },
];
---

<Layout
  title="關於我們 | 喬新針織．永立新國際"
  description={aboutDescription}
  keywords={aboutKeywords}
  canonical="/about"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <div class="ab">

    <!-- ① Hero -->
    <header class="ab-hero">
      <div class="ab-hero-img">
        <img src={`/${banner}`} alt="喬新針織台南官田工廠針織手套生產線，紅螞蟻手套製造現場" />
        <div class="ab-hero-overlay"></div>
      </div>
      <div class="ab-inner ab-hero-content">
        <p class="ab-eyebrow">關於喬新</p>
        <h1 class="ab-h1">喬新針織．永立新國際</h1>
        <p class="ab-hero-desc">全台最值得信賴的防護手套與五金耗材供應商</p>
        <div class="ab-btns">
          <a href="/products" class="ab-btn-primary">瀏覽產品目錄</a>
          <a href="/contact" class="ab-btn-ghost">立即詢價</a>
        </div>
      </div>
    </header>

    <!-- ② 公司簡介 -->
    <section class="ab-section">
      <div class="ab-inner">
        <div class="ab-intro-grid">
          <div class="ab-intro-lead">
            <span class="ab-chip-badge">COMPANY PROFILE</span>
            <h2 class="ab-h2">
              深耕台南二十餘載，<br />
              <span class="ab-accent-td">專業守護作業安全</span>
            </h2>
          </div>
          <div class="ab-intro-card">
            <p>
              喬新針織有限公司 / 永立新國際有限公司 (Chiaohsin Knitting Co., Ltd.)
              成立於 2003 年，總部位於台南市官田區。我們專精於各類針織工作手套與五金防護耗材的研發與供應，擁有超過 20 年的產業實務經驗。<strong class="ab-accent-td">「紅螞蟻手套」與「魚得水」皆為喬新針織旗下品牌</strong>，市面所見紅螞蟻手套產品皆由本公司製造供應。
            </p>
            <p>
              身為台南在地的指標性廠商，我們以<strong class="ab-accent-td">「穩定供貨、規格透明、誠信經營」</strong>為核心價值，不僅深耕在地工業區，服務範疇更覆蓋全台地區，是各大企業、工廠、批發商及物流體系的首選合作夥伴。
            </p>
            <div class="ab-quote">
              「手套封口部分為車頭，不會脫落，更加緊實的包覆著您的雙手」
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ③ 核心產品與服務 -->
    <section class="ab-section ab-section-alt">
      <div class="ab-inner">
        <div class="ab-products-grid">
          <div class="ab-products-lead">
            <span class="ab-chip-badge ab-chip-badge--teal">OUR PRODUCTS</span>
            <h2 class="ab-h2">
              核心產品與服務<br />
              <span class="ab-accent-teal">一站式防護方案</span>
            </h2>
            <p class="ab-sub-desc">我們提供多元且規格齊全的產品線，確保每一位勞動者在不同作業環境下都能獲得最合適的保護。</p>
          </div>
          <div class="ab-products-cards">
            {products.map((p) => (
              <div class="ab-card">
                <h3 class="ab-card-title">{p.title}</h3>
                <ul class="ab-card-list">
                  {p.items.map((item) => (
                    <li>
                      <span class={`ab-dot ab-dot--${p.color}`}></span>
                      <div>
                        <strong>{item.label}：</strong>
                        <span class="ab-sub-text">
                          {item.parts.map((part) =>
                            part.href ? <a href={part.href} class="ab-link">{part.text}</a> : part.text
                          )}
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ④ 核心競爭力 -->
    <section class="ab-section">
      <div class="ab-inner">
        <div class="ab-strength-grid">
          <div class="ab-strength-lead">
            <span class="ab-chip-badge ab-chip-badge--orange">WHY CHOOSE US</span>
            <h2 class="ab-h2">
              為什麼選擇我們？<br />
              <span class="ab-accent-td">三大核心競爭力</span>
            </h2>
            <p class="ab-sub-desc">長年深耕在地市場，了解勞動者需求，喬新/永立新給您最實在的承諾。</p>
          </div>
          <ol class="ab-strength-list">
            {strengths.map((item) => (
              <li class="ab-strength-item">
                <span class="ab-strength-num" aria-hidden="true">{item.n}</span>
                <div>
                  <h3 class="ab-strength-title">{item.title}</h3>
                  <p class="ab-sub-text">{item.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- ⑤ 常見問題 -->
    <section class="ab-section ab-section-alt">
      <div class="ab-inner">
        <div class="ab-faq-head">
          <span class="ab-chip-badge">FAQ</span>
          <h2 class="ab-h2">常見問題</h2>
        </div>
        <div class="ab-faq-list">
          {faqs.map((item, i) => (
            <details class="ab-faq-item" open={i === 0}>
              <summary class="ab-faq-q">
                <span>{item.q}</span>
                <svg class="ab-faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="ab-faq-a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑥ CTA -->
    <section class="ab-cta">
      <div class="ab-cta-blob ab-cta-blob-1"></div>
      <div class="ab-cta-blob ab-cta-blob-2"></div>
      <div class="ab-inner ab-cta-inner">
        <h2 class="ab-cta-title">即刻諮詢專屬防護方案</h2>
        <p class="ab-cta-sub">歡迎工廠、工地與批發商來電或 LINE 詢價，告知品項與數量，即可快速取得批發報價。</p>
        <div class="ab-btns ab-btns-center">
          <a href={`tel:${company.contact.phone}`} class="ab-btn-primary ab-btn-primary--onDark">{company.contact.phone}</a>
          <a href={`https://line.me/ti/p/~${LINE_ID}`} target="_blank" rel="noopener noreferrer" class="ab-btn-ghost">LINE 詢價</a>
        </div>
        <div class="ab-cta-meta">
          <span>週一至週六　08:00 – 18:00</span>
          <span class="ab-cta-meta-dot">|</span>
          <span>{company.address.full}</span>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .ab {
    --td:     #4A90A4;
    --teal:   #D4A574;
    --orange: #E0A458;
    --ink:    #1F2937;
    --sub:    #6B7280;
    --line:   #E6E4DE;
    --chip:   color-mix(in srgb, var(--td) 12%, white);
    --chip-teal: color-mix(in srgb, var(--teal) 18%, white);
    --chip-orange: color-mix(in srgb, var(--orange) 18%, white);
    --px: clamp(20px, 5vw, 64px);

    color: var(--ink);
    font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
  }

  .ab-inner { max-width: 1280px; margin-inline: auto; padding-inline: var(--px); }

  /* ══ Hero ══ */
  .ab-hero { position: relative; overflow: hidden; min-height: clamp(320px, 45vw, 460px); display: flex; align-items: flex-end; }
  .ab-hero-img { position: absolute; inset: 0; z-index: 0; }
  .ab-hero-img img { width: 100%; height: 100%; object-fit: cover; filter: brightness(.4); }
  .ab-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(150deg, color-mix(in srgb, var(--td) 55%, transparent) 0%, color-mix(in srgb, var(--teal) 45%, transparent) 70%);
  }
  .ab-hero-content { position: relative; z-index: 2; padding-block: clamp(28px, 5vw, 56px); }
  .ab-eyebrow { font-size: 11px; letter-spacing: 2px; color: var(--orange); font-weight: 700; margin: 0 0 10px; text-transform: uppercase; }
  .ab-h1 { font-size: clamp(22px, 4vw, 42px); font-weight: 900; line-height: 1.3; margin: 0 0 12px; color: #fff; letter-spacing: .02em; }
  .ab-hero-desc { font-size: clamp(13px, 1.5vw, 16px); line-height: 1.8; color: rgba(255,255,255,.85); margin: 0 0 24px; max-width: 520px; }

  .ab-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .ab-btns-center { justify-content: center; }
  .ab-btn-primary {
    background: var(--orange); color: #fff; border: none; border-radius: 8px;
    padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; cursor: pointer; transition: opacity .18s; display: inline-block;
  }
  .ab-btn-primary:hover { opacity: .88; }
  .ab-btn-primary--onDark { background: #fff; color: var(--td); }
  .ab-btn-ghost {
    background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.65);
    border-radius: 8px; padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; display: inline-block; transition: background .18s; cursor: pointer;
  }
  .ab-btn-ghost:hover { background: rgba(255,255,255,.13); }

  /* ══ 共用區塊節奏 ══ */
  .ab-section { padding-block: clamp(28px, 4vw, 56px); border-top: 1px solid var(--line); }
  .ab-section-alt { background: #fff; }
  .ab-h2 { font-size: clamp(20px, 2.8vw, 30px); font-weight: 900; line-height: 1.3; margin: 10px 0 10px; }
  .ab-sub-desc { font-size: clamp(13px, 1.3vw, 14.5px); color: var(--sub); line-height: 1.7; }
  .ab-sub-text { color: var(--sub); }
  .ab-accent-td { color: var(--td); }
  .ab-accent-teal { color: var(--teal); font-size: clamp(15px, 1.8vw, 20px); display: block; margin-top: 4px; }

  .ab-chip-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--td); background: var(--chip);
    padding: 6px 14px; border-radius: 999px;
  }
  .ab-chip-badge--teal { color: color-mix(in srgb, var(--teal) 70%, #6b4a1f); background: var(--chip-teal); }
  .ab-chip-badge--orange { color: color-mix(in srgb, var(--orange) 65%, #6b4a1f); background: var(--chip-orange); }

  /* ══ 公司簡介 ══ */
  .ab-intro-grid { display: flex; flex-direction: column; gap: 24px; }
  @media (min-width: 768px) { .ab-intro-grid { flex-direction: row; align-items: center; gap: clamp(24px, 4vw, 48px); } }
  .ab-intro-lead { flex: 0 0 auto; }
  @media (min-width: 768px) { .ab-intro-lead { flex: 0 0 32%; } }
  .ab-intro-card {
    flex: 1; background: #fff; border: 1px solid var(--line); border-radius: 14px;
    padding: clamp(20px, 2.6vw, 32px); font-size: clamp(13.5px, 1.2vw, 15.5px); line-height: 1.85; color: var(--sub);
  }
  .ab-intro-card p { margin: 0 0 16px; }
  .ab-intro-card p:last-of-type { margin-bottom: 0; }
  .ab-quote {
    margin-top: 20px; padding: 12px 18px; border-radius: 0 10px 10px 0;
    border-left: 4px solid var(--orange); background: color-mix(in srgb, var(--orange) 8%, white);
    color: var(--ink); font-weight: 700; font-style: italic; letter-spacing: .02em;
  }

  /* ══ 核心產品與服務 ══ */
  .ab-products-grid { display: flex; flex-direction: column-reverse; gap: 24px; }
  @media (min-width: 768px) { .ab-products-grid { flex-direction: row; align-items: center; gap: clamp(24px, 4vw, 48px); } }
  .ab-products-lead { flex: 0 0 auto; }
  @media (min-width: 768px) { .ab-products-lead { flex: 0 0 30%; } }
  .ab-products-cards { flex: 1; display: flex; flex-direction: column; gap: 14px; }
  .ab-card {
    background: var(--cream, #F7F6F3); border: 1px solid var(--line); border-radius: 12px;
    padding: clamp(16px, 2.2vw, 26px); transition: transform .2s;
  }
  .ab-card:hover { transform: translateY(-2px); }
  .ab-card-title { font-size: clamp(15.5px, 1.6vw, 18px); font-weight: 800; margin: 0 0 14px; }
  .ab-card-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .ab-card-list li { display: flex; align-items: flex-start; gap: 10px; font-size: clamp(12.5px, 1.1vw, 14px); line-height: 1.65; }
  .ab-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 6px; flex-shrink: 0; }
  .ab-dot--td { background: var(--td); }
  .ab-dot--teal { background: var(--teal); }
  .ab-link { color: var(--td); font-weight: 600; text-decoration: none; border-bottom: 1px dotted var(--td); }
  .ab-link:hover { border-bottom-style: solid; }

  /* ══ 核心競爭力 ══ */
  .ab-strength-grid { display: flex; flex-direction: column; gap: 24px; }
  @media (min-width: 640px) { .ab-strength-grid { flex-direction: row; align-items: flex-start; gap: clamp(24px, 4vw, 48px); } }
  .ab-strength-lead { flex: 0 0 auto; position: sticky; top: 84px; align-self: flex-start; }
  @media (min-width: 640px) { .ab-strength-lead { flex: 0 0 30%; } }
  .ab-strength-list { flex: 1; display: flex; flex-direction: column; gap: 12px; list-style: none; padding: 0; margin: 0; }
  .ab-strength-item {
    display: flex; gap: 16px; padding: clamp(14px, 1.8vw, 22px);
    border-radius: 12px; background: #fff; border: 1px solid var(--line);
    transition: border-color .18s, box-shadow .18s;
  }
