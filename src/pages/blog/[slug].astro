---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import company from "../../data/company.json";
import GloveSpecCard from "../../components/GloveSpecCard.astro";
import GloveInsight from "../../components/GloveInsight.astro";
import CauseList from "../../components/CauseList.astro";
import FaqSection from "../../components/FaqSection.astro";
import SelectionFlow from "../../components/SelectionFlow.astro";

const allDataFiles = import.meta.glob<{ default: any }>(
    "../../content/blog/*/data.json",
    { eager: true }
);

export async function getStaticPaths() {
    const dataFiles = import.meta.glob<{ default: any }>(
        "../../content/blog/*/data.json",
        { eager: true }
    );
    const posts = await getCollection("blog", ({ data }) => {
        return data.draft !== true;
    });

    return posts.map((post) => {
        const dataKey = Object.keys(dataFiles).find((key) =>
            key.includes(`/${post.id}/data.json`)
        );
        const blockData = dataKey ? dataFiles[dataKey].default : null;

        return {
            params: { slug: post.id },
            props: { post, blockData },
        };
    });
}

const { post, blockData } = Astro.props;
const { Content } = await render(post);
const processedHeroImage = await getImage({ src: post.data.image, width: 1200, height: 630 });

const wordCount = post.body ? post.body.length : 0;
const readingTime =
    blockData?.metadata?.readingTime ?? Math.ceil(wordCount / 400);

const pageTitle = `${post.data.title} - ${company.shortName}`;
const pageDescription = post.data.description;
const pageKeywords = post.data.tags || ["手套", "教學"];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? "https://www.chiaohsin.com.tw";

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: `${siteUrl}${processedHeroImage.src}`,
    datePublished: post.data.publishDate.toISOString(),
    author: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        url: `https://${company.website}`,
    },
    publisher: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/${company.logo}`,
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": `${siteUrl}/blog/${post.id}`,
    },
    url: `${siteUrl}/blog/${post.id}`,
    keywords: (post.data.tags || []).join(", "),
};

// HowTo Schema：標題含「如何」「指南」「選購」「選擇」「步驟」且有 summary 時產生
const isHowTo = post.data.summary && post.data.summary.length > 0 &&
    /如何|指南|選購|選擇|步驟|比較/.test(post.data.title);

const howToSchema = isHowTo ? {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: post.data.title,
    description: post.data.description,
    image: `${siteUrl}${processedHeroImage.src}`,
    step: post.data.summary.map((s: string, i: number) => ({
        "@type": "HowToStep",
        position: i + 1,
        text: s,
    })),
} : null;

// FAQPage Schema：從 blockData 提取 faq 類型的區塊
const faqItems = (blockData?.blocks ?? [])
    .filter((b: { type: string }) => b.type === "faq")
    .flatMap((b: { items: { question: string; answer: string }[] }) => b.items ?? []);

const faqSchema = faqItems.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item: { question: string; answer: string }) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
        },
    })),
} : null;

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "知識專欄", item: `${siteUrl}/blog` },
        { "@type": "ListItem", position: 3, name: post.data.title, item: `${siteUrl}/blog/${post.id}` },
    ],
};

const proseClass =
    "prose prose-lg max-w-none " +
    "prose-headings:text-gray-900 prose-headings:font-bold " +
    "prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-6 prose-h2:pb-4 prose-h2:border-b prose-h2:border-gray-100 " +
    "prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4 " +
    "prose-p:text-gray-600 prose-p:leading-8 prose-p:mb-6 " +
    "prose-li:text-gray-600 prose-li:leading-7 " +
    "prose-strong:text-gray-900 prose-strong:font-semibold " +
    "prose-a:text-primary prose-a:font-medium prose-a:no-underline hover:prose-a:underline " +
    "prose-blockquote:not-italic prose-blockquote:text-gray-700 " +
    "prose-img:rounded-2xl prose-img:shadow-xl prose-img:my-10 " +
    "prose-table:border-collapse prose-table:w-full " +
    "prose-th:bg-gray-50 prose-th:p-4 prose-th:text-left " +
    "prose-td:p-4 prose-td:border-b prose-td:border-gray-50";
---

<Layout
    title={pageTitle}
    description={pageDescription}
    keywords={pageKeywords}
    canonical={`/blog/${post.id}`}
    ogImage={processedHeroImage.src}
    ogType="article"
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify(articleSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(breadcrumbSchema)}
        />
        {faqSchema && (
            <script
                type="application/ld+json"
                set:html={JSON.stringify(faqSchema)}
            />
        )}
        {howToSchema && (
            <script
                type="application/ld+json"
                set:html={JSON.stringify(howToSchema)}
            />
        )}
    </Fragment>
    <!-- Featured Image at the Top -->
    <div class="max-w-5xl mx-auto px-4 pt-8">
        <div
            class="aspect-[21/9] overflow-hidden rounded-3xl border-4 border-white container-no-shadow"
        >
            <Image
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-full object-cover"
                width={1200}
                height={514}
            />
        </div>
    </div>

    <!-- Article Header -->
    <div class="relative overflow-hidden py-12 px-4">
        <div class="max-w-4xl mx-auto relative z-10">
            <nav class="text-sm breadcrumbs mb-8">
                <ul class="flex items-center gap-2 text-gray-500">
                    <li>
                        <a href="/" class="hover:text-primary transition-colors"
                            >首頁</a
                        >
                    </li>
                    <li class="before:content-['/'] before:mr-2">
                        <a
                            href="/blog"
                            class="hover:text-primary transition-colors"
                            >知識專欄</a
                        >
                    </li>
                    {
                        post.data.category &&
                            post.data.category !== post.data.title && (
                                <li class="before:content-['/'] before:mr-2">
                                    <span class="text-gray-400">
                                        {post.data.category}
                                    </span>
                                </li>
                            )
                    }
                </ul>
            </nav>

            <div class="flex flex-wrap items-center gap-4 text-sm mb-6">
                {
                    post.data.category && (
                        <div class="px-3 py-1 rounded-full bg-primary/10 text-primary font-medium">
                            {post.data.category}
                        </div>
                    )
                }
                <div class="flex items-center gap-4 text-gray-500 ml-auto">
                    <div class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 10h18"/></svg>
                        <time datetime={post.data.publishDate.toISOString()}>
                            {
                                post.data.publishDate.toLocaleDateString(
                                    "zh-TW",
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )
                            }
                        </time>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>
                        <span>{readingTime} 分鐘</span>
                    </div>
                </div>
            </div>

            <h1
                class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight text-gray-900 leading-tight"
            >
                {post.data.title}
            </h1>

            <p class="text-xl text-gray-600 leading-relaxed">
                {post.data.description}
            </p>

            {post.data.summary && post.data.summary.length > 0 && (
                <div class="mt-8 bg-primary/5 border-l-4 border-primary rounded-r-xl px-6 py-5">
                    <p class="text-xs font-semibold text-primary uppercase tracking-widest mb-3">本文重點</p>
                    <ul class="space-y-2">
                        {post.data.summary.map((point: string) => (
                            <li class="flex items-start gap-2 text-gray-700 text-sm leading-relaxed">
                                <span class="text-primary mt-0.5 shrink-0">✓</span>
                                <span>{point}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            )}
        </div>
    </div>

    <!-- Article Content -->
    <article class="pb-16 px-4">
        <div class="max-w-4xl mx-auto">
            {
                blockData?.blocks ? (
                    blockData.blocks.map((block: any) => (
                        <>
                            {block.type === "prose" && (
                                <div class={proseClass} set:html={block.html} />
                            )}
                            {block.type === "spec_cards" && (
                                <div
                                    class={`my-8 grid ${block.cols === 2 ? "md:grid-cols-2" : "md:grid-cols-3"} gap-6`}
                                >
                                    {block.items.map((item: any) => (
                                        <GloveSpecCard
                                            number={item.title}
                                            subtitle={item.subtitle}
                                            badgeLabel={item.badge.label}
                                            badgeType={item.badge.type}
                                            specs={item.metrics}
                                            tags={item.tags}
                                            featured={item.featured ?? false}
                                        />
                                    ))}
                                </div>
                            )}
                            {block.type === "insight" && (
                                <GloveInsight
                                    type={block.variant}
                                    title={block.title}
                                    content={block.content}
                                />
                            )}
                            {block.type === "cause_list" && (
                                <div class="my-8">
                                    <CauseList causes={block.items} />
                                </div>
                            )}
                            {block.type === "selection_flow" && (
                                <div class="my-8">
                                    <SelectionFlow steps={block.steps} />
                                </div>
                            )}
                            {block.type === "comparison_table" && (
                                <div class="overflow-x-auto my-8 bg-white border border-gray-200 rounded-2xl">
                                    <table class="w-full text-sm">
                                        <thead class="bg-gray-50 border-b border-gray-200">
                                            <tr>
                                                {block.headers.map(
                                                    (h: string) => (
                                                        <th class="px-6 py-3 text-left font-semibold text-gray-900">
                                                            {h}
                                                        </th>
                                                    ),
                                                )}
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-200">
                                            {block.rows.map(
                                                (row: string[]) => (
                                                    <tr>
                                                        {row.map(
                                                            (
                                                                cell: string,
                                                                i: number,
                                                            ) =>
                                                                i === 0 ? (
                                                                    <td class="px-6 py-4 font-semibold text-gray-900">
                                                                        {cell}
                                                                    </td>
                                                                ) : (
                                                                    <td class="px-6 py-4 text-gray-600">
                                                                        {cell}
                                                                    </td>
                                                                ),
                                                        )}
                                                    </tr>
                                                ),
                                            )}
                                        </tbody>
                                    </table>
                                </div>
                            )}
                            {block.type === "faq" && (
                                <div class="my-8">
                                    <FaqSection items={block.items} />
                                </div>
                            )}
                        </>
                    ))
                ) : (
                    <div class={proseClass}>
                        <Content />
                    </div>
                )
            }

            {
                post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-12 pt-8 border-t border-gray-100">
                        <div class="flex flex-wrap gap-2">
                            {post.data.tags.map((tag: string) => (
                                <span class="px-3 py-1 rounded-lg bg-gray-100 text-gray-600 text-sm">
                                    #{tag}
                                </span>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </article>

    <!-- Post Side Actions -->
    <div class="max-w-4xl mx-auto px-4 pb-16">
        <div
            class="p-8 rounded-3xl bg-primary/5 border border-primary/10 flex flex-col md:flex-row items-center justify-between gap-8"
        >
            <div class="text-center md:text-left">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">
                    找到合適的手套了嗎？
                </h3>
                <p class="text-gray-600">
                    如果有任何挑選上的困難，我們的專業團隊隨時為您服務。
                </p>
            </div>
            <div class="flex flex-wrap justify-center gap-4">
                <a
                    href="/about#contact"
                    class="px-8 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20"
                >
                    立即諮詢
                </a>
                <a
                    href="/products"
                    class="px-8 py-3 rounded-xl bg-white text-primary border border-primary/20 font-bold hover:bg-primary/5 transition-all"
                >
                    瀏覽所有商品
                </a>
            </div>
        </div>
    </div>

    <!-- Back Navigation -->
    <section class="py-12 border-t border-gray-100">
        <div class="max-w-4xl mx-auto px-4">
            <a
                href="/blog"
                class="inline-flex items-center text-gray-500 hover:text-primary transition-colors font-medium"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5 mr-2"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                返回文章列表
            </a>
        </div>
    </section>
</Layout>

<style is:global>
    .prose blockquote {
        @apply border-l-4 border-primary bg-primary/5 px-6 py-4 rounded-r-xl not-italic text-gray-700;
    }

    .prose ul > li {
        @apply relative pl-1;
    }
</style>
