---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import { getCollection, render } from "astro:content";
import company from "../../data/company.json";

export async function getStaticPaths() {
    const allNews = await getCollection("news", ({ data }) => data.draft !== true);
    return allNews.map((item) => ({
        params: { slug: item.id.replace(/\/index$/, '') },
        props: { item },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? "https://www.chiaohsin.com.tw";
const pageTitle = `${item.data.title} - ${company.shortName}`;
const pageDescription = item.data.description;
const slug = item.id.replace(/\/index$/, '');

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: item.data.title,
    description: item.data.description,
    datePublished: item.data.publishDate.toISOString(),
    dateModified: item.data.publishDate.toISOString(),
    author: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        url: `https://${company.website}`,
    },
    publisher: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/${company.logo}`,
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": `${siteUrl}/news/${slug}`,
    },
    url: `${siteUrl}/news/${slug}`,
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "最新消息", item: `${siteUrl}/news` },
        { "@type": "ListItem", position: 3, name: item.data.title, item: `${siteUrl}/news/${slug}` },
    ],
};

const faqSchema = item.data.faq && item.data.faq.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: item.data.faq.map((f: { q: string; a: string }) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: {
            "@type": "Answer",
            text: f.a,
        },
    })),
} : null;

const proseClass =
    "prose prose-lg max-w-none " +
    "prose-headings:text-gray-900 prose-headings:font-bold " +
    "prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-gray-100 " +
    "prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 " +
    "prose-p:text-gray-600 prose-p:leading-8 prose-p:mb-4 " +
    "prose-li:text-gray-600 prose-li:leading-7 " +
    "prose-strong:text-gray-900 prose-strong:font-semibold " +
    "prose-a:text-primary prose-a:font-medium prose-a:no-underline hover:prose-a:underline";
---

<Layout
    title={pageTitle}
    description={pageDescription}
    keywords={item.data.tags ?? []}
    canonical={`/news/${slug}`}
    ogType="article"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        {faqSchema && (
            <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
        )}
    </Fragment>

    <PageHero title={item.data.title} eyebrow="最新消息">
        <nav slot="breadcrumb" class="ph-breadcrumb" aria-label="breadcrumb">
            <a href="/">首頁</a>
            <span class="ph-breadcrumb-sep" aria-hidden="true">／</span>
            <a href="/news">最新消息</a>
            <span class="ph-breadcrumb-sep" aria-hidden="true">／</span>
            <span class="ph-breadcrumb-cur">{item.data.title}</span>
        </nav>
    </PageHero>

    <div class="max-w-3xl mx-auto px-4 py-12">

        <time
            class="text-sm text-gray-500 block mb-3"
            datetime={item.data.publishDate.toISOString()}
        >
            {item.data.publishDate.toLocaleDateString("zh-TW", {
                year: "numeric",
                month: "long",
                day: "numeric",
            })}
        </time>

        <p class="text-lg text-gray-500 mb-8 pb-8 border-b border-gray-100">
            {item.data.description}
        </p>

        <article class={proseClass}>
            <Content />
        </article>

        {item.data.tags && item.data.tags.length > 0 && (
            <div class="mt-10 pt-8 border-t border-gray-100 flex flex-wrap gap-2">
                {item.data.tags.map((tag: string) => (
                    <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-sm">#{tag}</span>
                ))}
            </div>
        )}

    </div>

    <section class="nc-cta">
        <div class="nc-blob nc-blob-1"></div>
        <div class="nc-blob nc-blob-2"></div>
        <div class="nc-inner">
            <h2 class="nc-title">需要批發報價？</h2>
            <p class="nc-sub">歡迎工廠、工地與批發商來電或 LINE 詢價，告知品項與數量，即可快速取得批發報價。</p>
            <div class="nc-btns">
                <a href={`tel:${company.contact.phone}`} class="nc-btn-primary">{company.contact.phone}</a>
                <a href={`https://line.me/ti/p/~${company.contact["LINE ID"]}`} target="_blank" rel="noopener noreferrer" class="nc-btn-ghost">LINE 詢價</a>
            </div>
            <div class="nc-meta">
                <span>週一至週六　08:00 – 18:00</span>
                <span class="nc-meta-dot">|</span>
                <span>{company.address.full}</span>
            </div>
        </div>
    </section>

<style>
  .nc-cta {
    background: linear-gradient(135deg, #4A90A4 0%, color-mix(in srgb, #4A90A4 90%, white) 55%, #D4A574 100%);
    color: #fff;
    padding-block: clamp(36px, 5vw, 64px);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .nc-blob { position: absolute; border-radius: 50%; background: rgba(255,255,255,.06); pointer-events: none; }
  .nc-blob-1 { width: 240px; height: 240px; top: -70px; right: -60px; }
  .nc-blob-2 { width: 190px; height: 190px; bottom: -60px; left: -40px; }
  .nc-inner { position: relative; z-index: 2; padding-inline: clamp(20px, 5vw, 64px); max-width: 1280px; margin-inline: auto; }
  .nc-title { font-size: clamp(20px, 3vw, 32px); font-weight: 800; margin: 0 0 10px; }
  .nc-sub { font-size: clamp(13px, 1.4vw, 16px); opacity: .85; margin: 0 0 28px; max-width: 520px; margin-inline: auto; }
  .nc-btns { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .nc-btn-primary {
    background: #fff; color: #4A90A4; border: none; border-radius: 8px;
    padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; cursor: pointer; transition: opacity .18s; display: inline-block;
  }
  .nc-btn-primary:hover { opacity: .9; }
  .nc-btn-ghost {
    background: rgba(255,255,255,.12); color: #fff; border: 1.5px solid rgba(255,255,255,.35);
    border-radius: 8px; padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; display: inline-block; transition: background .18s; cursor: pointer;
  }
  .nc-btn-ghost:hover { background: rgba(255,255,255,.2); }
  .nc-meta {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 6px 14px;
    margin-top: 24px; font-size: 12.5px; color: rgba(255,255,255,.65);
  }
  .nc-meta-dot { opacity: .5; }
</style>

</Layout>
