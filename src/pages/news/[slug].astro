---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import company from "../../data/company.json";

export async function getStaticPaths() {
    const allNews = await getCollection("news", ({ data }) => data.draft !== true);
    return allNews.map((item) => ({
        params: { slug: item.id.replace(/\/index$/, '') },
        props: { item },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? "https://www.chiaohsin.com.tw";
const pageTitle = `${item.data.title} - ${company.shortName}`;
const pageDescription = item.data.description;
const slug = item.id.replace(/\/index$/, '');

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: item.data.title,
    description: item.data.description,
    datePublished: item.data.publishDate.toISOString(),
    author: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        url: `https://${company.website}`,
    },
    publisher: {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: company.shortName,
        logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/${company.logo}`,
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": `${siteUrl}/news/${slug}`,
    },
    url: `${siteUrl}/news/${slug}`,
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "最新消息", item: `${siteUrl}/news` },
        { "@type": "ListItem", position: 3, name: item.data.title, item: `${siteUrl}/news/${slug}` },
    ],
};

const proseClass =
    "prose prose-lg max-w-none " +
    "prose-headings:text-gray-900 prose-headings:font-bold " +
    "prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-gray-100 " +
    "prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 " +
    "prose-p:text-gray-600 prose-p:leading-8 prose-p:mb-4 " +
    "prose-li:text-gray-600 prose-li:leading-7 " +
    "prose-strong:text-gray-900 prose-strong:font-semibold " +
    "prose-a:text-primary prose-a:font-medium prose-a:no-underline hover:prose-a:underline";
---

<Layout
    title={pageTitle}
    description={pageDescription}
    keywords={item.data.tags ?? []}
    canonical={`/news/${slug}`}
    ogType="article"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    </Fragment>

    <div class="max-w-3xl mx-auto px-4 py-12">

        <nav class="text-sm mb-8">
            <ul class="flex items-center gap-2 text-gray-400">
                <li><a href="/" class="hover:text-primary transition-colors">首頁</a></li>
                <li class="before:content-['/'] before:mr-2">
                    <a href="/news" class="hover:text-primary transition-colors">最新消息</a>
                </li>
            </ul>
        </nav>

        <time
            class="text-sm text-gray-400 block mb-3"
            datetime={item.data.publishDate.toISOString()}
        >
            {item.data.publishDate.toLocaleDateString("zh-TW", {
                year: "numeric",
                month: "long",
                day: "numeric",
            })}
        </time>

        <h1 class="text-3xl md:text-4xl font-extrabold mb-6 text-gray-900 leading-tight">
            {item.data.title}
        </h1>

        <p class="text-lg text-gray-500 mb-8 pb-8 border-b border-gray-100">
            {item.data.description}
        </p>

        <article class={proseClass}>
            <Content />
        </article>

        {item.data.tags && item.data.tags.length > 0 && (
            <div class="mt-10 pt-8 border-t border-gray-100 flex flex-wrap gap-2">
                {item.data.tags.map((tag: string) => (
                    <span class="px-3 py-1 rounded-lg bg-gray-100 text-gray-500 text-sm">#{tag}</span>
                ))}
            </div>
        )}

        <div class="mt-12 p-8 rounded-2xl bg-primary/5 border border-primary/10 text-center">
            <h3 class="text-xl font-bold mb-2">需要批發報價？</h3>
            <p class="text-gray-600 mb-4">歡迎來電或 LINE 詢價，告知品項與數量即可快速報價</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="/products" class="btn btn-primary">查看所有商品</a>
                <a href="/contact" class="btn btn-outline">聯絡我們</a>
            </div>
        </div>

        <div class="mt-10">
            <a href="/news" class="inline-flex items-center text-gray-500 hover:text-primary transition-colors font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                返回最新消息
            </a>
        </div>

    </div>
</Layout>
