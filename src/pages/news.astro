---
import Layout from "../layouts/Layout.astro";
import company from "../data/company.json";
import seo from "../data/seo.json";

// 最新消息頁面 SEO 設定
const newsDescription = `${company.name}最新消息 - 了解我們的最新產品資訊、公司動態與優惠活動。`;
const newsKeywords = [
  company.name,
  "最新消息",
  "公司動態",
  ...seo.keywords.slice(0, 5),
];
---

<Layout
  title="最新消息"
  description={newsDescription}
  keywords={newsKeywords}
  canonical="/news"
>
  <div class="hero min-h-[50vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <h1 class="text-5xl font-bold">最新消息</h1>
        <p class="py-6">目前沒有最新消息發布。</p>
        <a href="/" class="btn btn-primary">回首頁</a>
      </div>
    </div>
  </div>
</Layout>
