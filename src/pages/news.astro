---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { getCollection } from "astro:content";
import company from "../data/company.json";

const siteUrl = "https://chiaohsin.com.tw";

const allNews = await getCollection("news", ({ data }) => data.draft !== true);
const sortedNews = allNews.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const pageTitle = `最新消息 - ${company.shortName}`;
const pageDescription = `${company.shortName}最新消息：新品上架公告、庫存備貨通知、工作手套優惠資訊，定期更新，掌握棉紗手套批發動態。`;

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": `${siteUrl}/news`,
  name: `${company.shortName}最新消息`,
  url: `${siteUrl}/news`,
  description: pageDescription,
  inLanguage: "zh-TW",
  publisher: {
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: company.shortName,
  },
};

const newsItemListSchema = sortedNews.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${company.shortName}最新消息列表`,
  numberOfItems: sortedNews.length,
  itemListElement: sortedNews.map((item, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    name: item.data.title,
    url: `${siteUrl}/news/${item.id.replace(/\/index$/, "")}`,
  })),
} : null;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "最新消息", item: `${siteUrl}/news` },
  ],
};
---

<Layout
    title={pageTitle}
    description={pageDescription}
    keywords={["喬新針織最新消息", "台南棉紗手套批發公告", "工安耗材新品上架"]}
    canonical="/news"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {newsItemListSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(newsItemListSchema)} />
    )}
  </Fragment>
    <PageHero title="喬新針織最新消息｜棉紗手套批發公告與產品動態" description="新品上架公告、庫存備貨通知、喬新針織公司動態，掌握棉紗手套批發最新資訊">
      <nav slot="breadcrumb" class="ph-breadcrumb" aria-label="breadcrumb">
        <a href="/">首頁</a>
        <span class="ph-breadcrumb-sep" aria-hidden="true">／</span>
        <span class="ph-breadcrumb-cur">最新消息</span>
      </nav>
    </PageHero>

    <section class="py-16 px-4 bg-base-100">
        <div class="max-w-4xl mx-auto">
            {sortedNews.length > 0 ? (
                <div class="space-y-6">
                    {sortedNews.map((item) => (
                        <a href={`/news/${item.id.replace(/\/index$/, '')}`} class="group block">
                            <article class="card bg-base-100 shadow-md hover:shadow-xl transition-all duration-300 border border-[#E6E4DE] p-6">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1">
                                        <time
                                            class="text-sm text-gray-500 block mb-2"
                                            datetime={item.data.publishDate.toISOString()}
                                        >
                                            {item.data.publishDate.toLocaleDateString("zh-TW", {
                                                year: "numeric",
                                                month: "long",
                                                day: "numeric",
                                            })}
                                        </time>
                                        <h2 class="text-xl font-bold group-hover:text-primary transition-colors mb-2">
                                            {item.data.title}
                                        </h2>
                                        <p class="text-gray-500 line-clamp-2">
                                            {item.data.description}
                                        </p>
                                        {item.data.tags && item.data.tags.length > 0 && (
                                            <div class="flex flex-wrap gap-2 mt-3">
                                                {item.data.tags.map((tag: string) => (
                                                    <span class="px-2 py-1 rounded-md bg-gray-100 text-gray-600 text-xs">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        )}
                                    </div>
                                    <span class="text-primary group-hover:translate-x-1 transition-transform mt-1 shrink-0">
                                        閱讀 →
                                    </span>
                                </div>
                            </article>
                        </a>
                    ))}
                </div>
            ) : (
                <div class="text-center py-16">
                    <h2 class="text-2xl font-bold mb-2">目前沒有消息</h2>
                    <p class="text-gray-500">請稍後再來查看。</p>
                </div>
            )}
        </div>
    </section>
</Layout>
