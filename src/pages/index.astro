---
import Layout from '../layouts/Layout.astro';
import company from '../data/company.json';
import categories from '../data/categories.json';
import products from '../data/products.json';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { productThumb } from '../utils/image';

const LINE_ID = company.contact['LINE ID'];

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const byCategory: Record<string, typeof products> = {};
for (const p of products) {
  if (p.available === false) continue;
  if (!byCategory[p.category]) byCategory[p.category] = [];
  byCategory[p.category].push(p);
}

const gloveTabs = [
  { id: 'cotton-gloves',       label: '棉紗手套' },
  { id: 'rubber-gloves',       label: '膠手套' },
  { id: 'nylon-gloves',        label: '尼龍手套' },
  { id: 'white-dragon-gloves', label: '白龍手套' },
  { id: 'flower-dragon-gloves',label: '花龍手套' },
  { id: 'special-gloves',      label: '特殊手套' },
];
const hwProducts  = byCategory['hardware']  ?? [];
const pkgProducts = byCategory['packaging'] ?? [];
const totalGloveProducts = gloveTabs.reduce((sum, tab) => sum + (byCategory[tab.id]?.length ?? 0), 0);

const SHELF_IDS = new Set(['cotton-gloves','rubber-gloves','nylon-gloves','white-dragon-gloves','flower-dragon-gloves','special-gloves','hardware','packaging']);
const otherCats = categories.filter(c => !SHELF_IDS.has(c.id));

function articleFilter(post: typeof sortedPosts[0]): string {
  const tags  = post.data.tags ?? [];
  const title = post.data.title;
  if (tags.some(t => t.includes('材質') || t.includes('比較')) || title.includes('比較') || /\bvs\b/i.test(title)) return '材質比較';
  if (title.includes('保養') || title.includes('維護')) return '使用維護';
  if (title.includes('食品') || title.includes('電鍍') || title.includes('化工') || title.includes('物流') || title.includes('產業')) return '產業應用';
  return '選購指南';
}

const homeFaqs = [
  {
    q: '喬新針織主要賣什麼？跟紅螞蟻手套是什麼關係？',
    a: '「紅螞蟻手套」是喬新針織有限公司的自有品牌，公司成立於 2003 年，位於台南市官田區，主要生產與批發棉紗手套、NBR/PVC 膠手套、尼龍手套、白龍花龍手套，以及口罩、包裝材料等工安耗材，長期供應製造業、物流業、工程業等企業客戶。',
  },
  {
    q: '可以少量訂購嗎？還是一定要大量批發？',
    a: '最低訂購量依品項而異，歡迎來電 06-6900359 或透過線上詢價洽詢確認的數量，客製規格請來電詢問。',
  },
  {
    q: '配送範圍有涵蓋全台灣嗎？大概多久出貨？',
    a: '全台皆可配送。現貨商品原則上 3 個工作日內出貨，下單後可與業務確認實際出貨時間。',
  },
  {
    q: '除了手套，還有賣什麼耗材？',
    a: '除了各式工作手套，我們也供應口罩、包裝材料（PE膜、膠帶）、建築五金、太空包、清潔用品、交通安全用品、無塵室耗材等工安相關商品，一次採購省去多方比價的麻煩。',
  },
  {
    q: '怎麼詢價？需要準備什麼資訊？',
    a: `提供需要的手套材質、針數/兩數規格與大概數量，透過 LINE（ID：${LINE_ID}）或電話 ${company.contact.phone} 聯繫業務，就能快速取得報價。`,
  },
];

const homeFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaqs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout
  title="工作手套批發直營｜棉紗、膠手套、口罩・紅螞蟻手套・台南喬新針織"
  description="台南喬新針織（紅螞蟻手套）成立 2003 年，專營棉紗手套、NBR/PVC 膠手套、尼龍手套、口罩批發直營，另供應五金耗材、包裝材料、太空包等工安用品，質量足重、工廠直供、全台配送，歡迎企業來電詢價。"
  canonical="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(homeFaqSchema)} />
  </Fragment>

  <div class="hp">

    <!-- ① Hero -->
    <section class="hp-hero">
      <div class="hp-inner">
        <p class="hp-eyebrow">台南・紅螞蟻手套</p>
        <h1 class="hp-h1">棉紗手套・膠手套・工作防護用品批發直營</h1>
        <p class="hp-desc">專業製造・品質保證・台灣製造，為您的工作環境提供最可靠的防護解決方案</p>
        <div class="hp-btns">
          <a href="/products" class="hp-btn-primary">瀏覽所有產品</a>
          <a href="/contact" class="hp-btn-ghost">聯絡我們</a>
        </div>
      </div>
    </section>

    <!-- ② 全分類快速導覽 -->
    <div class="hp-qnav-wrap">
      <div class="hp-qnav-outer">
        <p class="hp-qnav-label">全部分類</p>
        <nav class="hp-qnav" aria-label="產品分類">
          {categories.map(cat => (
            <a class="hp-qn-item" href={`/products#${cat.id}`} title={cat.name}>
              <div class="hp-qn-icon">
                {/* 手套類：統一 24×24，rect 掌心 + 4 指，細節區分材質 */}
                {cat.id === 'cotton-gloves'        && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><line x1="3" y1="17" x2="21" y2="17" stroke-dasharray="2 1.5"/></svg>}
                {cat.id === 'rubber-gloves'        && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><path d="M2 19.5h20" stroke-width="2.5"/></svg>}
                {cat.id === 'nylon-gloves'         && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><line x1="2" y1="13.5" x2="22" y2="21.5" stroke-dasharray="2 2" stroke-width="1"/><line x1="2" y1="17.5" x2="15" y2="22" stroke-dasharray="2 2" stroke-width="1"/></svg>}
                {cat.id === 'white-dragon-gloves'  && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/></svg>}
                {cat.id === 'flower-dragon-gloves' && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><circle cx="7" cy="18.5" r="1.5"/><circle cx="12" cy="18.5" r="1.5"/><circle cx="17" cy="18.5" r="1.5"/></svg>}
                {/* 口罩：保留原版 */}
                {cat.id === 'masks'                && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M3 11c0-2 2-3 5-4l4-1.5L16 7c3 1 5 2 5 4v3c0 3-4 5.5-9 5.5S3 17 3 14v-3z"/><path d="M7 13h10M8 16h8"/></svg>}
                {/* 膠帶捲：雙同心圓 + 拉舌線 */}
                {cat.id === 'packaging'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="M18.5 5.5l2-2M20.5 3.5l1 1-1.5 3"/></svg>}
                {/* 扳手：保留 */}
                {cat.id === 'hardware'             && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94L5.83 19.83a2 2 0 01-2.83-2.83l7.94-7.94A6 6 0 0114.7 6.3z"/></svg>}
                {/* 太空包：束口麻袋形（矩形袋身 + 頂部吊耳） */}
                {cat.id === 'bulk-bags'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M5 9h14v9.5c0 2-1.5 3-4 3H9c-2.5 0-4-1-4-3V9z"/><path d="M7 9V6M17 9V6M6 6h12"/><line x1="5" y1="14.5" x2="19" y2="14.5" stroke-dasharray="2 2"/></svg>}
                {/* 清潔用品：保留 */}
                {cat.id === 'cleaning'             && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M9 3h6l1 8H8L9 3z"/><path d="M7 11v8a1 1 0 001 1h8a1 1 0 001-1v-8"/><path d="M10 15h4"/></svg>}
                {/* 特殊手套：手套 + 掌心星形 */}
                {cat.id === 'special-gloves'       && <svg viewBox="0 0 24 24" stroke-width="1.8"><rect x="2" y="13" width="20" height="9" rx="2.5"/><path d="M5 13V9a1.5 1.5 0 013 0v4M9 13V7a1.5 1.5 0 013 0v6M13 13V8a1.5 1.5 0 013 0v5M17 13V10a1.5 1.5 0 013 0v3"/><path d="M12 15l.9 1.8 1.9.3-1.4 1.4.3 1.9-1.7-.9-1.7.9.3-1.9-1.4-1.4 1.9-.3z"/></svg>}
                {/* 交通安全：保留 */}
                {cat.id === 'traffic-safety'       && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M12 3L7 20h10L12 3z"/><path d="M8.5 14h7M9.5 17.5h5"/></svg>}
                {/* 無塵室：盾形 + 漸縮過濾線 */}
                {cat.id === 'cleanroom'            && <svg viewBox="0 0 24 24" stroke-width="1.8"><path d="M12 3L4 6v5c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6l-8-3z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="7.5" y1="13" x2="16.5" y2="13"/><line x1="9" y1="16" x2="15" y2="16"/></svg>}
                {/* 其他：保留 */}
                {cat.id === 'others'               && <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>}
              </div>
              <span class="hp-qn-label">{cat.name}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ③ 貨架區 -->
    <section class="hp-shelves">
      <div class="hp-inner">
        <h2 class="hp-shelves-title">產品分類</h2>
      </div>

      <!-- 手套類 -->
      <div class="hp-inner">
        <div class="hp-cat-hdr">
          <span class="hp-cat-name">手套類</span>
          <a class="hp-cat-more" href="/products">
            <span class="hp-cat-cnt">共 {totalGloveProducts} 款</span>查看全部 →
          </a>
        </div>
        <div class="hp-gtabs" id="hpGloveTabs">
          {gloveTabs.map((tab, i) => {
            const cnt = byCategory[tab.id]?.length ?? 0;
            return (
              <button class={`hp-gtab${i === 0 ? ' active' : ''}`} data-tab={tab.id}>
                {tab.label} <small style="opacity:.6">{cnt}</small>
              </button>
            );
          })}
        </div>
      </div>

      <div class="hp-sh-outer">
        <a class="hp-anchor" href="/products">
          <div class="hp-anchor-block hp-anchor-glove">
            <span class="hp-anchor-big">手套類</span>
            <span class="hp-anchor-en">GLOVES</span>
          </div>
          <div class="hp-anchor-foot">
            <span class="hp-anchor-count">共 {totalGloveProducts} 款</span>
            <span class="hp-anchor-arr">→</span>
          </div>
        </a>
        <div class="hp-sh-right" id="hpSrGloves">
          {gloveTabs.map((tab, i) => {
            const ps = byCategory[tab.id] ?? [];
            return (
              <div class={`hp-sh-panel${i === 0 ? ' active' : ''}`} id={`hpanel-${tab.id}`}>
                {ps.map((p, idx) => (
                  <a class="hp-item" href={`/products/${p.id}`}>
                    <div class="hp-item-img">
                      <img src={`/${productThumb(p.image)}`} alt={p.name} loading={i === 0 && idx < 2 ? "eager" : "lazy"} fetchpriority={i === 0 && idx === 0 ? "high" : undefined} width="160" height="160" />
                    </div>
                    <p class="hp-item-name">{p.name}</p>
                    {p.features?.[0] && <span class="hp-item-spec">{p.features[0]}</span>}
                  </a>
                ))}
              </div>
            );
          })}
          <button class="hp-sh-btn hp-sh-btn-l gone" id="hpBlGloves" aria-label="向左捲動">‹</button>
          <button class="hp-sh-btn hp-sh-btn-r" id="hpBrGloves" aria-label="向右捲動">›</button>
        </div>
      </div>

      <!-- 建築五金 -->
      <div class="hp-inner hp-shelf-gap">
        <div class="hp-cat-hdr">
          <span class="hp-cat-name">建築五金</span>
          <a class="hp-cat-more" href="/products#hardware">
            <span class="hp-cat-cnt">共 {hwProducts.length} 款</span>查看全部 →
          </a>
        </div>
      </div>
      <div class="hp-sh-outer">
        <a class="hp-anchor" href="/products#hardware">
          <div class="hp-anchor-block hp-anchor-orange">
            <span class="hp-anchor-big">建築五金</span>
            <span class="hp-anchor-en">HARDWARE</span>
          </div>
          <div class="hp-anchor-foot">
            <span class="hp-anchor-count">共 {hwProducts.length} 款</span>
            <span class="hp-anchor-arr">→</span>
          </div>
        </a>
        <div class="hp-sh-right" id="hpSrHw">
          <div class="hp-sh-row">
            {hwProducts.map((p) => (
              <a class="hp-item" href={`/products/${p.id}`}>
                <div class="hp-item-img">
                  <img src={`/${productThumb(p.image)}`} alt={p.name} loading="lazy" width="160" height="160" />
                </div>
                <p class="hp-item-name">{p.name}</p>
                {p.features?.[0] && <span class="hp-item-spec">{p.features[0]}</span>}
              </a>
            ))}
          </div>
          <button class="hp-sh-btn hp-sh-btn-l gone" id="hpBlHw" aria-label="向左捲動">‹</button>
          <button class="hp-sh-btn hp-sh-btn-r" id="hpBrHw" aria-label="向右捲動">›</button>
        </div>
      </div>

      <!-- 包裝材料 -->
      <div class="hp-inner hp-shelf-gap">
        <div class="hp-cat-hdr">
          <span class="hp-cat-name">包裝材料</span>
          <a class="hp-cat-more" href="/products#packaging">
            <span class="hp-cat-cnt">共 {pkgProducts.length} 款</span>查看全部 →
          </a>
        </div>
      </div>
      <div class="hp-sh-outer">
        <a class="hp-anchor" href="/products#packaging">
          <div class="hp-anchor-block hp-anchor-slate">
            <span class="hp-anchor-big">包裝材料</span>
            <span class="hp-anchor-en">PACKAGING</span>
          </div>
          <div class="hp-anchor-foot">
            <span class="hp-anchor-count">共 {pkgProducts.length} 款</span>
            <span class="hp-anchor-arr">→</span>
          </div>
        </a>
        <div class="hp-sh-right" id="hpSrPkg">
          <div class="hp-sh-row">
            {pkgProducts.map((p) => (
              <a class="hp-item" href={`/products/${p.id}`}>
                <div class="hp-item-img">
                  <img src={`/${productThumb(p.image)}`} alt={p.name} loading="lazy" width="160" height="160" />
                </div>
                <p class="hp-item-name">{p.name}</p>
                {p.features?.[0] && <span class="hp-item-spec">{p.features[0]}</span>}
              </a>
            ))}
          </div>
          <button class="hp-sh-btn hp-sh-btn-l gone" id="hpBlPkg" aria-label="向左捲動">‹</button>
          <button class="hp-sh-btn hp-sh-btn-r" id="hpBrPkg" aria-label="向右捲動">›</button>
        </div>
      </div>
    </section>

    <!-- ④ 其他分類 -->
    <div class="hp-other">
      <div class="hp-inner">
        <p class="hp-other-title">其他分類</p>
        <div class="hp-chip-grid">
          {otherCats.map(cat => (
            <a class="hp-chip" href={`/products#${cat.id}`}>{cat.name}</a>
          ))}
          <a class="hp-chip-all" href="/products">查看全部 {categories.length} 項 →</a>
        </div>
      </div>
    </div>

    <!-- ⑤ 文章區 -->
    <section class="hp-articles">
      <div class="hp-inner">
        <h2 class="hp-articles-title">選購指南</h2>
        <p class="hp-articles-sub">專業教學文章，幫助您選擇最適合的防護用品</p>
        <div class="hp-pills" id="hpPills">
          <button class="hp-pill active" data-filter="全部">全部</button>
          <button class="hp-pill" data-filter="選購指南">選購指南</button>
          <button class="hp-pill" data-filter="材質比較">材質比較</button>
          <button class="hp-pill" data-filter="使用維護">使用維護</button>
          <button class="hp-pill" data-filter="產業應用">產業應用</button>
        </div>
        <div class="hp-article-grid" id="hpArticleGrid">
          {sortedPosts.map(post => (
            <a class="hp-article-card" href={`/blog/${post.id.replace(/\/index$/, '')}`} data-filter={articleFilter(post)}>
              <div class="hp-article-img">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  loading="lazy"
                  width={400}
                  height={225}
                  widths={[300, 400, 600]}
                  sizes="(min-width: 1024px) 22vw, (min-width: 640px) 30vw, 45vw"
                />
                <span class="hp-article-badge">文章</span>
              </div>
              <p class="hp-article-title">{post.data.title}</p>
            </a>
          ))}
        </div>
        <div class="hp-articles-more">
          <a href="/blog" class="hp-btn-outline">查看所有文章 →</a>
        </div>
      </div>
    </section>

    <!-- ⑥ 常見問題 -->
    <section class="hp-faq">
      <div class="hp-inner">
        <h2 class="hp-faq-title">常見問題</h2>
        <div class="hp-faq-list">
          {homeFaqs.map((item, i) => (
            <details class="hp-faq-item" open={i === 0}>
              <summary class="hp-faq-q">
                <span>{item.q}</span>
                <svg class="hp-faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p class="hp-faq-a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ⑦ CTA -->
    <section class="hp-cta">
      <div class="hp-cta-blob hp-cta-blob-1"></div>
      <div class="hp-cta-blob hp-cta-blob-2"></div>
      <div class="hp-inner">
        <h2 class="hp-cta-title">即刻諮詢專屬防護方案</h2>
        <p class="hp-cta-sub">歡迎工廠、工地與批發商來電或 LINE 詢價，告知品項與數量，即可快速取得批發報價。</p>
        <div class="hp-cta-btns">
          <a href={`tel:${company.contact.phone}`} class="hp-btn-primary">{company.contact.phone}</a>
          <a href={`https://line.me/ti/p/~${LINE_ID}`} target="_blank" rel="noopener noreferrer" class="hp-btn-ghost">LINE 詢價</a>
        </div>
        <div class="hp-cta-meta">
          <span>週一至週六　08:00 – 18:00</span>
          <span class="hp-cta-meta-dot">|</span>
          <span>{company.address.full}</span>
        </div>
      </div>
    </section>

  </div>
</Layout>

<script>
  /* ── 左右捲動箭頭 ── */
  function setupCarouselHandlers(
    rightId: string, blId: string, brId: string, isTabbed: boolean
  ): (() => void) | undefined {
    const bl = document.getElementById(blId);
    const br = document.getElementById(brId);
    if (!bl || !br) return;

    function getTrack(): HTMLElement | null {
      if (isTabbed) return document.querySelector(`#${rightId} .hp-sh-panel.active`) as HTMLElement | null;
      return document.querySelector(`#${rightId} .hp-sh-row`) as HTMLElement | null;
    }

    function sync() {
      const t = getTrack();
      if (!t) return;
      bl.classList.toggle('gone', t.scrollLeft <= 4);
      br.classList.toggle('gone', t.scrollLeft + t.clientWidth >= t.scrollWidth - 4);
    }

    bl.addEventListener('click', () => {
      const t = getTrack();
      if (t) t.scrollBy({ left: -(t.clientWidth * 0.8), behavior: 'smooth' });
    });
    br.addEventListener('click', () => {
      const t = getTrack();
      if (t) t.scrollBy({ left: t.clientWidth * 0.8, behavior: 'smooth' });
    });

    // 延遲掛載 scroll 監聽與初始同步（不阻塞首屏）
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => {
        document.getElementById(rightId)?.addEventListener('scroll', sync, { passive: true, capture: true });
        sync();
      }, { timeout: 2000 });
    } else {
      setTimeout(() => {
        document.getElementById(rightId)?.addEventListener('scroll', sync, { passive: true, capture: true });
        sync();
      }, 1500);
    }

    return sync;
  }

  const syncGloves = setupCarouselHandlers('hpSrGloves', 'hpBlGloves', 'hpBrGloves', true);
  const syncHw  = setupCarouselHandlers('hpSrHw',  'hpBlHw',  'hpBrHw',  false);
  const syncPkg = setupCarouselHandlers('hpSrPkg', 'hpBlPkg', 'hpBrPkg', false);

  // 單一 resize listener，避免重複掛載
  if ('requestIdleCallback' in window) {
    requestIdleCallback(() => {
      window.addEventListener('resize', () => setTimeout(() => {
        syncGloves?.(); syncHw?.(); syncPkg?.();
      }, 60), { passive: true });
    }, { timeout: 2000 });
  } else {
    setTimeout(() => {
      window.addEventListener('resize', () => setTimeout(() => {
        syncGloves?.(); syncHw?.(); syncPkg?.();
      }, 60), { passive: true });
    }, 1500);
  }

  /* ── 手套 tab 切換（立即掛載，避免首屏點擊無反應）── */
  document.getElementById('hpGloveTabs')?.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.hp-gtab') as HTMLElement | null;
    if (!btn) return;
    document.querySelectorAll('.hp-gtab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.hp-sh-panel').forEach(p => p.classList.remove('active'));
    const panel = document.getElementById(`hpanel-${btn.dataset.tab}`) as HTMLElement | null;
    if (panel) { panel.classList.add('active'); panel.scrollLeft = 0; }
    setTimeout(() => syncGloves?.(), 20);
  });

  /* ── 文章篩選（延遲初始化，非首屏關鍵交互）── */
  if ('requestIdleCallback' in window) {
    requestIdleCallback(() => {
      document.getElementById('hpPills')?.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('.hp-pill') as HTMLElement | null;
        if (!btn) return;
        document.querySelectorAll('.hp-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const f = btn.dataset.filter;
        document.querySelectorAll<HTMLElement>('.hp-article-card').forEach(card => {
          card.style.display = (f === '全部' || card.dataset.filter === f) ? '' : 'none';
        });
      });
    }, { timeout: 3000 });
  } else {
    setTimeout(() => {
      document.getElementById('hpPills')?.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('.hp-pill') as HTMLElement | null;
        if (!btn) return;
        document.querySelectorAll('.hp-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const f = btn.dataset.filter;
        document.querySelectorAll<HTMLElement>('.hp-article-card').forEach(card => {
          card.style.display = (f === '全部' || card.dataset.filter === f) ? '' : 'none';
        });
      });
    }, 2000);
  }
</script>

<style>
  /* ══ 全域設定 ══ */
  .hp {
    --td:     #4A90A4;
    --teal:   #D4A574;
    --orange: #E0A458;
    --ink:    #1F2937;
    --sub:    #6B7280;
    --cream:  #F7F6F3;
    --white:  #FFFFFF;
    --line:   #E6E4DE;
    --chip:   color-mix(in srgb, var(--td) 12%, white);
    --px: clamp(20px, 5vw, 64px);
    --iw: clamp(88px, 22vw, 120px);   /* 商品卡寬度 */
    --aw: clamp(96px, 13vw, 120px);   /* 錨點卡寬度 */

    background: var(--cream);
    color: var(--ink);
    font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
  }
  @media (min-width: 1024px) {
    .hp {
      --iw: clamp(150px, 14vw, 190px);
      --aw: clamp(120px, 10vw, 140px);
    }
  }

  .hp-inner {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--px);
  }

  /* ══ Hero ══ */
  .hp-hero {
    background: linear-gradient(150deg, var(--td) 0%, var(--teal) 65%);
    color: #fff;
    padding-block: clamp(28px, 5vw, 56px);
  }
  .hp-eyebrow { font-size: 11px; letter-spacing: 2px; color: var(--orange); font-weight: 700; margin: 0 0 10px; text-transform: uppercase; }
  .hp-h1 { font-size: clamp(22px, 4vw, 42px); font-weight: 800; line-height: 1.3; margin: 0 0 12px; }
  .hp-desc { font-size: clamp(13px, 1.5vw, 16px); line-height: 1.8; opacity: .85; margin: 0 0 24px; max-width: 520px; }
  .hp-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .hp-btn-primary {
    background: var(--orange); color: #fff; border: none; border-radius: 8px;
    padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; cursor: pointer; transition: opacity .18s; display: inline-block;
  }
  .hp-btn-primary:hover { opacity: .88; }
  .hp-btn-ghost {
    background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.65);
    border-radius: 8px; padding: 11px 24px; font-size: clamp(13px, 1.4vw, 15px); font-weight: 700;
    text-decoration: none; display: inline-block; transition: background .18s; cursor: pointer;
  }
  .hp-btn-ghost:hover { background: rgba(255,255,255,.13); }

  /* ══ 快速導覽 ══ */
  .hp-qnav-wrap { background: var(--white); border-bottom: 1px solid var(--line); }

  /* 手機：右側漸層 + scroll-snap */
  @media (max-width: 1023px) {
    .hp-qnav-wrap { position: relative; }
    .hp-qnav-wrap::after {
      content: '';
      position: absolute;
      top: 0; right: 0; bottom: 0;
      width: 56px;
      background: linear-gradient(to right, transparent, #fff);
      pointer-events: none;
      z-index: 1;
    }
  }

  /* 手機：padding 由子元素控制 */
  .hp-qnav-label { font-size: 12px; font-weight: 700; color: var(--sub); margin: 0 0 10px; padding-inline: var(--px); padding-top: 14px; display: block; }
  .hp-qnav {
    display: flex; gap: clamp(14px, 2.5vw, 28px);
    overflow-x: auto; padding-inline: var(--px); padding-bottom: 10px;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }
  .hp-qnav::-webkit-scrollbar { display: none; }
  .hp-qn-item {
    flex: 0 0 auto; display: flex; flex-direction: column; align-items: center;
    gap: 6px; width: clamp(52px, 7vw, 68px); text-decoration: none; color: var(--ink);
    scroll-snap-align: start;
  }
  .hp-qn-icon {
    width: clamp(44px, 6vw, 58px); height: clamp(44px, 6vw, 58px);
    border-radius: 50%; background: var(--chip);
    display: flex; align-items: center; justify-content: center; transition: background .18s;
  }
  .hp-qn-item:hover .hp-qn-icon { background: color-mix(in srgb, var(--td) 22%, white); }
  .hp-qn-icon svg { width: 46%; height: 46%; stroke: var(--td); fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .hp-qn-label { font-size: clamp(9.5px, 1.1vw, 11.5px); text-align: center; white-space: nowrap; line-height: 1.3; }

  /* 桌機：整組置中，14 欄等距，不捲動 */
  @media (min-width: 1024px) {
    .hp-qnav-outer {
      max-width: 1280px;
      margin-inline: auto;
      padding-inline: var(--px);
      padding-block: 14px 10px;
    }
    .hp-qnav-label { padding-inline: 0; padding-top: 0; margin-bottom: 12px; }
    .hp-qnav {
      display: grid;
      grid-template-columns: repeat(14, 1fr);
      overflow-x: visible;
      padding-inline: 0;
      padding-bottom: 0;
      gap: 4px;
    }
    .hp-qn-item { width: auto; }
  }

  /* ══ 貨架區 ══ */
  .hp-shelves { padding: 24px 0 8px; }
  .hp-shelves-title { font-size: clamp(18px, 2.5vw, 26px); font-weight: 800; margin: 0 0 16px; }
  .hp-shelf-gap { margin-top: 24px; }

  /* 分類標題列 */
  .hp-cat-hdr { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .hp-cat-name { font-size: clamp(15px, 1.6vw, 18px); font-weight: 800; }
  .hp-cat-more { font-size: 13px; font-weight: 700; color: var(--teal); white-space: nowrap; text-decoration: none; }
  .hp-cat-more:hover { color: var(--td); }
  .hp-cat-cnt { font-size: 11px; color: var(--sub); font-weight: 400; margin-right: 3px; }

  /* 手套 tab */
  .hp-gtabs { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; margin-bottom: 12px; }
  .hp-gtabs::-webkit-scrollbar { display: none; }
  .hp-gtab {
    flex: 0 0 auto; font-size: 12px; font-weight: 700;
    padding: 6px 14px; border-radius: 999px;
    background: var(--white); border: 1.5px solid var(--line); color: var(--sub);
    cursor: pointer; white-space: nowrap; transition: all .18s;
  }
  .hp-gtab:hover { border-color: var(--teal); color: var(--td); }
  .hp-gtab.active { background: var(--td); color: #fff; border-color: var(--td); }

  /* ── 兩欄貨架：錨點卡 ＋ 單行捲動 ── */
  .hp-sh-outer {
    display: flex;
    align-items: stretch;
    gap: 8px;
    padding-left: var(--px);
    margin-bottom: 4px;
    max-width: 1280px;
    margin-inline: auto;
  }
  @media (min-width: 1024px) {
    .hp-sh-outer { padding-right: var(--px); }
  }

  /* 錨點卡（左側固定，與商品卡等高） */
  .hp-anchor {
    flex: 0 0 var(--aw);
    background: var(--white); border: 1px solid var(--line); border-radius: 12px;
    overflow: hidden; text-decoration: none; color: inherit;
    display: flex; flex-direction: column; transition: box-shadow .18s;
  }
  .hp-anchor { transition: transform .22s cubic-bezier(.34,1.56,.64,1); }
  .hp-anchor:hover { transform: scale(.97); }
  .hp-anchor-block { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; padding: 12px 8px; }
  .hp-anchor-glove { background: linear-gradient(160deg, var(--td), var(--teal)); }
  .hp-anchor-orange { background: linear-gradient(160deg, #F0B86B, #8B4A2B); }
  .hp-anchor-slate  { background: linear-gradient(160deg, #9DB8C9, #3E5568); }
  .hp-anchor-big { font-size: clamp(15px, 1.6vw, 20px); font-weight: 900; color: #fff; letter-spacing: .04em; line-height: 1.2; text-align: center; }
  .hp-anchor-en  { font-size: clamp(7px, .8vw, 9px); font-weight: 700; color: rgba(255,255,255,.65); letter-spacing: .12em; }
  .hp-anchor-foot { padding: 8px 10px; display: flex; align-items: center; justify-content: space-between; }
  .hp-anchor-count { font-size: 10px; color: var(--sub); }
  .hp-anchor-arr  { font-size: 14px; font-weight: 900; color: var(--teal); }

  /* 右側：捲動區 */
  .hp-sh-right {
    flex: 1;
    min-width: 0;
    position: relative;
    overflow: hidden;
  }

  /* 商品列（手機橫滑） */
  .hp-sh-row, .hp-sh-panel {
    display: flex;
    gap: clamp(8px, 1.5vw, 12px);
    overflow-x: auto;
    padding-right: var(--px);
    padding-bottom: 16px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }
  .hp-sh-row::-webkit-scrollbar,
  .hp-sh-panel::-webkit-scrollbar { display: none; }
  .hp-sh-panel { display: none; }
  .hp-sh-panel.active { display: flex; }

  /* 商品小卡 */
  .hp-item {
    flex: 0 0 var(--iw);
    display: flex; flex-direction: column; gap: 6px;
    text-decoration: none; color: inherit; scroll-snap-align: start;
  }
  .hp-item-img {
    aspect-ratio: 1/1; background: var(--white);
    border: 1px solid var(--line); border-radius: 10px;
    overflow: hidden; display: flex; align-items: center; justify-content: center;
    transition: box-shadow .18s;
  }
  .hp-item:hover .hp-item-img { box-shadow: 0 2px 10px rgba(0,0,0,.1); }
  .hp-item-img img { width: 100%; height: 100%; object-fit: cover; }
  .hp-item-name {
    font-size: clamp(11px, 1.1vw, 13px); font-weight: 600; line-height: 1.4; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .hp-item-spec {
    font-size: clamp(9.5px, 0.9vw, 11px); color: var(--td); background: var(--chip);
    padding: 1px 6px; border-radius: 999px; width: fit-content; display: inline-block;
  }

  /* 左右箭頭按鈕 */
  .hp-sh-btn {
    position: absolute;
    top: 50%;
    transform: translateY(calc(-50% - 8px));
    z-index: 4;
    width: clamp(28px, 3vw, 36px);
    height: clamp(28px, 3vw, 36px);
    border-radius: 50%;
    background: rgba(255,255,255,.96);
    border: 1.5px solid var(--line);
    box-shadow: 0 2px 10px rgba(0,0,0,.15);
    color: var(--td);
    font-size: clamp(14px, 1.8vw, 20px);
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .2s, box-shadow .18s;
    padding: 0;
  }
  .hp-sh-btn:hover { box-shadow: 0 4px 16px rgba(0,0,0,.2); }
  .hp-sh-btn.gone { opacity: 0; pointer-events: none; }
  .hp-sh-btn-l { left: 4px; }
  .hp-sh-btn-r { right: 4px; }

  /* ══ 其他分類 ══ */
  .hp-other { padding-block: 8px 24px; border-top: 1px solid var(--line); margin-top: 8px; }
  .hp-other-title { font-size: 13px; font-weight: 700; color: var(--sub); margin: 0 0 10px; }
  .hp-chip-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .hp-chip {
    font-size: clamp(12px, 1.1vw, 13.5px); font-weight: 600;
    padding: 9px 14px; border-radius: 10px;
    background: var(--white); border: 1px solid var(--line); color: var(--ink);
    text-decoration: none; transition: all .18s;
  }
  .hp-chip:hover { background: var(--chip); border-color: var(--teal); color: var(--td); }
  .hp-chip-all {
    font-size: clamp(12px, 1.1vw, 13.5px); font-weight: 700;
    padding: 9px 14px; border-radius: 10px;
    background: var(--td); color: #fff; text-decoration: none; transition: opacity .18s;
  }
  .hp-chip-all:hover { opacity: .85; }

  /* ══ 文章區 ══ */
  .hp-articles { padding-block: 32px; border-top: 1px solid var(--line); }
  .hp-articles-title { font-size: clamp(18px, 2.5vw, 26px); font-weight: 800; margin: 0 0 4px; }
  .hp-articles-sub { font-size: 13px; color: var(--sub); margin: 0 0 16px; }
  /* 手機隱藏 pill 篩選器 */
  .hp-pills { display: none; gap: 8px; overflow-x: auto; scrollbar-width: none; margin-bottom: 20px; }
  .hp-pills::-webkit-scrollbar { display: none; }
  @media (min-width: 640px) { .hp-pills { display: flex; } }
  .hp-pill {
    flex: 0 0 auto; font-size: 12.5px; font-weight: 700;
    padding: 8px 16px; border-radius: 999px;
    background: var(--white); border: 1.5px solid var(--line); color: var(--ink);
    cursor: pointer; white-space: nowrap; transition: all .18s;
  }
  .hp-pill:hover { border-color: var(--teal); color: var(--td); }
  .hp-pill.active { background: var(--td); color: #fff; border-color: var(--td); }
  .hp-article-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: clamp(10px, 2vw, 18px);
  }
  @media (min-width: 640px)  { .hp-article-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .hp-article-grid { grid-template-columns: repeat(4, 1fr); } }
  /* 手機：只顯示前4篇；平板以上：顯示前8篇 */
  .hp-article-card:nth-child(n+5) { display: none; }
  @media (min-width: 640px) {
    .hp-article-card:nth-child(n+5) { display: flex; }
    .hp-article-card:nth-child(n+9) { display: none; }
  }

  .hp-article-card { text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 8px; transition: opacity .2s; }
  .hp-article-card:hover { opacity: .85; }
  .hp-article-img {
    aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; position: relative;
    background: linear-gradient(135deg, #d8c6a8, #c2ab86);
  }
  .hp-article-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hp-article-badge {
    position: absolute; top: 8px; left: 8px;
    background: rgba(255,255,255,.92); color: var(--ink);
    font-size: 9px; font-weight: 800; padding: 3px 7px; border-radius: 5px;
  }
  .hp-article-title {
    font-size: clamp(12.5px, 1.1vw, 14px); font-weight: 700; line-height: 1.5; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .hp-articles-more { text-align: center; margin-top: 28px; }
  .hp-btn-outline {
    display: inline-block; font-size: 14px; font-weight: 700;
    padding: 11px 28px; border-radius: 8px;
    border: 2px solid var(--td); color: var(--td);
    text-decoration: none; transition: all .18s;
  }
  .hp-btn-outline:hover { background: var(--td); color: #fff; }

  /* ══ 常見問題 ══ */
  .hp-faq { padding-block: 32px; border-top: 1px solid var(--line); }
  .hp-faq-title { font-size: clamp(18px, 2.5vw, 26px); font-weight: 800; margin: 0 0 16px; }
  .hp-faq-list { display: flex; flex-direction: column; gap: 10px; }
  .hp-faq-item {
    border: 1px solid var(--line); border-radius: 12px; background: var(--cream);
    overflow: hidden; padding: 0;
  }
  .hp-faq-q {
    cursor: pointer; list-style: none;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: clamp(14px, 1.8vw, 18px) clamp(16px, 2vw, 22px);
    font-size: clamp(13.5px, 1.3vw, 15px); font-weight: 700; color: var(--ink);
  }
  .hp-faq-q::-webkit-details-marker { display: none; }
  .hp-faq-chevron { width: 16px; height: 16px; flex-shrink: 0; color: var(--td); transition: transform .2s; }
  .hp-faq-item[open] .hp-faq-chevron { transform: rotate(180deg); }
  .hp-faq-a {
    margin: 0; padding: 0 clamp(16px, 2vw, 22px) clamp(14px, 1.8vw, 18px);
    font-size: clamp(12.5px, 1.15vw, 14px); line-height: 1.75; color: var(--sub);
    background: var(--white);
  }

  /* ══ CTA ══ */
  .hp-cta {
    background: linear-gradient(135deg,
      var(--td) 0%,
      color-mix(in srgb, var(--td) 90%, white) 55%,
      color-mix(in srgb, var(--teal) 70%, white) 100%);
    color: #fff; padding-block: clamp(36px, 5vw, 64px); text-align: center;
    position: relative; overflow: hidden;
  }
  .hp-cta-blob { position: absolute; border-radius: 50%; background: rgba(255,255,255,.06); pointer-events: none; }
  .hp-cta-blob-1 { width: 240px; height: 240px; top: -70px; right: -60px; }
  .hp-cta-blob-2 { width: 190px; height: 190px; bottom: -60px; left: -40px; }
  .hp-cta .hp-inner { position: relative; z-index: 2; }
  .hp-cta-title { font-size: clamp(20px, 3vw, 32px); font-weight: 800; margin: 0 0 10px; }
  .hp-cta-sub { font-size: clamp(13px, 1.4vw, 16px); opacity: .85; margin: 0 0 28px; max-width: 520px; margin-inline: auto; }
  .hp-cta-btns { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .hp-cta .hp-btn-primary { background: #fff; color: var(--td); }
  .hp-cta .hp-btn-primary:hover { opacity: .9; }
  .hp-cta .hp-btn-ghost { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.35); }
  .hp-cta .hp-btn-ghost:hover { background: rgba(255,255,255,.2); }
  .hp-cta-meta {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 6px 14px;
    margin-top: 24px; font-size: 12.5px; color: rgba(255,255,255,.65);
  }
  .hp-cta-meta-dot { opacity: .5; }
</style>
