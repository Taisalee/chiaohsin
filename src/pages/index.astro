---
import Layout from '../layouts/Layout.astro';
import company from '../data/company.json';
import categories from '../data/categories.json';
import seo from '../data/seo.json';
import { getCollection } from 'astro:content';

const { banner } = company.assets.images;

// 取得精選文章（最新 3 篇）
const allPosts = await getCollection('blog', ({ data }) => {
    return data.draft !== true;
});
const featuredPosts = allPosts
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .slice(0, 3);

// 首頁 SEO 設定
const homeDescription = `${company.name} - ${company.tagline}。${company.description.slice(0, 100)}`;
const homeKeywords = [
  company.name,
  company.englishName,
];
---

<Layout 
  title={company.tagline}
  description={homeDescription}
  keywords={homeKeywords}
  canonical="/"
>
  <!-- Hero Section -->
  <div class="hero min-h-[70vh] bg-base-200" style={`background-image: url(/${banner});`}>
    <div class="hero-overlay bg-opacity-60 bg-gradient-to-r from-neutral-900/80 to-transparent"></div>
    <div class="hero-content text-center text-neutral-content w-full justify-start px-4 md:px-12">
      <div class="max-w-2xl text-left">
        <h1 class="mb-5 text-5xl font-bold leading-tight animate-fade-in-up">
          {company.name}
        </h1>
        <p class="mb-5 text-2xl font-light text-gray-200 animate-fade-in-up delay-100">
          {company.tagline}
        </p>
        <p class="mb-8 text-lg animate-fade-in-up delay-200">
          {company.slogan}
        </p>
        <div class="flex gap-4 animate-fade-in-up delay-300">
          <a href="/products" class="btn btn-primary border-none text-white hover:scale-105 transition-transform">
            瀏覽產品
          </a>
          <a href="/about#contact" class="btn btn-outline text-white hover:bg-white hover:text-neutral transition-colors">
            聯絡我們
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- About Section -->
  <section class="py-20 px-4 bg-base-100">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">關於我們</h2>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <div class="p-8 bg-base-200 rounded-2xl shadow-xl relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-2 h-full bg-primary transition-all group-hover:w-full group-hover:opacity-10"></div>
            <p class="text-lg leading-relaxed relative z-10">
              {company.description}
            </p>
          </div>
        </div>
        <div class="flex-1 space-y-4">
          <div class="stats shadow w-full">
            <div class="stat place-items-center">
              <div class="stat-title">成立於</div>
              <div class="stat-value text-primary">台灣</div>
              <div class="stat-desc">台南官田</div>
            </div>
            <div class="stat place-items-center">
              <div class="stat-title">產品種類</div>
              <div class="stat-value text-secondary">100+</div>
              <div class="stat-desc">滿足各種需求</div>
            </div>
          </div>
          <div class="alert alert-info shadow-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <div>
              <h3 class="font-bold">品質保證</h3>
              <div class="text-xs">重量足，品質好，深受客戶信任</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-20 px-4 bg-base-200">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">產品分類</h2>
        <p class="text-xl text-gray-500">多樣化的防護產品，全方位守護您的安全</p>
        <div class="w-24 h-1 bg-secondary mx-auto mt-4 rounded-full"></div>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map((cat) => (
          <a href={`/products#${cat.id}`} class="group">
            <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 h-full border-t-4" style={`border-color: ${cat.color || '#ccc'}`}>
              <div class="card-body items-center text-center">
                <h3 class="card-title text-2xl">{cat.name}</h3>
                <p class="text-gray-500 text-sm line-clamp-3">{cat.description}</p>
                <div class="card-actions mt-4">
                  <span class="btn btn-sm btn-ghost group-hover:btn-primary transition-colors">查看更多 -></span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Section: 如何挑選手套 -->
  <section class="py-20 px-4 bg-base-100">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">如何挑選手套</h2>
        <p class="text-xl text-gray-500">專業教學文章，幫助您選擇最適合的工作防護用品</p>
        <div class="w-24 h-1 bg-accent mx-auto mt-4 rounded-full"></div>
      </div>
      
      {featuredPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="group">
              <article class="card bg-base-100 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 h-full border border-base-200 hover:border-primary/30">
                <div class="card-body">
                  {post.data.category && (
                    <div class="badge badge-accent badge-outline mb-2">
                      {post.data.category}
                    </div>
                  )}
                  <h3 class="card-title text-xl group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-gray-500 line-clamp-3">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between mt-4 pt-4 border-t border-base-200">
                    <time class="text-sm text-gray-400" datetime={post.data.publishDate.toISOString()}>
                      {post.data.publishDate.toLocaleDateString('zh-TW', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                    <span class="text-primary group-hover:translate-x-1 transition-transform inline-block">
                      閱讀更多 →
                    </span>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-8">
          <div class="text-5xl mb-4">📝</div>
          <p class="text-gray-500">教學文章即將推出，敬請期待！</p>
        </div>
      )}
      
      <div class="text-center mt-12">
        <a href="/blog" class="btn btn-outline btn-lg hover:btn-accent transition-colors">
          查看所有文章 →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-gradient-to-r from-neutral to-neutral-focus text-neutral-content">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">需要專業的防護建議？</h2>
      <p class="text-xl mb-8 opacity-90">我們提供最優質的手套與防護用品，歡迎來電洽詢或親臨選購</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="tel:{company.contact.phone}" class="btn btn-primary btn-lg shadow-lg">
          📞 立即來電 {company.contact.phone}
        </a>
        <a href="/about#contact" class="btn btn-outline btn-lg text-white hover:bg-white hover:text-neutral">
          查看交通位置
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
