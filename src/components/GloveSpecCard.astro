---
// 规格卡片组件 - 展示针数或两数规格
interface Props {
  number: string;
  subtitle: string;
  badgeLabel: string;
  badgeType: 'coral' | 'green' | 'best';
  specs: Array<{
    label: string;
    value: string;
    percentage: number;
  }>;
  tags: string[];
  featured?: boolean;
}

const { number, subtitle, badgeLabel, badgeType, specs, tags, featured = false } = Astro.props;

const badgeColors = {
  coral: 'bg-red-100 text-red-700',
  green: 'bg-green-100 text-green-700',
  best: 'bg-blue-100 text-blue-700',
};

const barColors = {
  coral: 'bg-red-600',
  green: 'bg-green-600',
  best: 'bg-blue-600',
};
---

<div class={`rounded-2xl border-2 overflow-hidden transition-all duration-300 ${
  featured ? 'border-blue-500 bg-blue-50/30' : 'border-gray-200 bg-white hover:shadow-lg'
}`}>
  <div class="p-6">
    <div class={`inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4 ${badgeColors[badgeType]}`}>
      {badgeLabel}
    </div>

    <div class="text-4xl font-bold text-gray-900 mb-1">{number}</div>
    <p class="text-sm text-gray-500 mb-4">{subtitle}</p>

    <!-- Progress bars -->
    <div class="space-y-3 mb-4">
      {specs.map((spec) => (
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-gray-600">{spec.label}</span>
            <span class="text-gray-500">{spec.value}</span>
          </div>
          <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div
              class="h-full bg-blue-600 rounded-full transition-all duration-300"
              style={`width: ${spec.percentage}%`}
            ></div>
          </div>
        </div>
      ))}
    </div>

    <div class="border-t border-gray-200 pt-4 mt-4">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200 text-gray-600 bg-gray-50">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
