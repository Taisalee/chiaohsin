---
interface Props {
  number: string;
  subtitle: string;
  badgeLabel: string;
  badgeType: 'coral' | 'green' | 'best' | 'warning';
  specs: Array<{
    label: string;
    value: string;
    percentage?: number;
  }>;
  tags: string[];
  featured?: boolean;
}

const { number, subtitle, badgeLabel, specs, tags, featured = false } = Astro.props;
---

<div class={`rounded-2xl overflow-hidden transition-all duration-300 ${
  featured
    ? 'border-t-4 border-primary bg-primary/5 shadow-lg'
    : 'border-t-4 border-gray-200 bg-white shadow-sm hover:shadow-md'
}`}>
  <div class="p-6">
    <div class={`inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4 ${
      featured ? 'bg-primary text-white' : 'bg-primary/10 text-primary'
    }`}>
      {featured ? '★ 推薦首選' : badgeLabel}
    </div>

    <div class="text-4xl font-bold text-gray-900 mb-1">{number}</div>
    <p class="text-sm text-gray-500 mb-4">{subtitle}</p>

    <div class="space-y-3 mb-4">
      {specs.map((spec) => (
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-gray-600">{spec.label}</span>
            <span class="text-gray-500">{spec.value}</span>
          </div>
          {spec.percentage !== undefined && (
            <div class={`h-1.5 rounded-full overflow-hidden ${featured ? 'bg-primary/10' : 'bg-gray-100'}`}>
              <div
                class="h-full bg-primary rounded-full transition-all duration-300"
                style={`width: ${spec.percentage}%`}
              ></div>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="border-t border-gray-200 pt-4 mt-4">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class={`text-xs px-2.5 py-1 rounded-full border ${
            featured
              ? 'border-primary/20 text-primary bg-primary/5'
              : 'border-gray-200 text-gray-600 bg-gray-50'
          }`}>
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
