---
import { productThumb } from "../utils/image";

interface Props {
    id: string;
    name: string;
    image: string;
    description: string;
    size?: string;
    category?: string;
    tags?: string[];
    categoryName?: string;
}

const { id, name, image, description, size, category = "", tags = [], categoryName = "" } = Astro.props;

const altText = categoryName
    ? `${name}${size && size !== "-" ? ` ${size}` : ""} ${categoryName}批發 - 喬新針織`
    : `${name} 產品圖片`;
---

<a
    href={`/products/${id}`}
    class="prd-card product-card"
    data-product-id={id}
    data-product-name={name}
    data-product-description={description}
    data-product-category={category}
    data-product-tags={tags.join(" ")}
>
    <div class="prd-card-img">
        <img
            src={`/${productThumb(image)}`}
            alt={altText}
            loading="lazy"
            width="300"
            height="300"
        />
    </div>
    <div class="prd-card-body">
        <div class="prd-card-title-row">
            <span class="prd-card-name">{name}</span>
            {size && size !== "-" && (
                <span class="prd-size-badge">{size}</span>
            )}
        </div>
        <p class="prd-card-desc">{description}</p>
        </div>
</a>

<style>
    .prd-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        box-shadow: 0 1px 4px rgba(0,0,0,.07);
        transition: transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .18s;
    }
    .prd-card:hover {
        transform: scale(.97);
        box-shadow: 0 4px 16px rgba(0,0,0,.11);
    }
    .prd-card-img {
        aspect-ratio: 1 / 1;
        background: #fff;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .prd-card-img img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 16px;
        transition: transform .3s ease;
    }
    .prd-card:hover .prd-card-img img { transform: scale(1.04); }
    .prd-card-body {
        padding: 12px 14px 14px;
        background: #F3F4F6;
        display: flex;
        flex-direction: column;
        flex: 1;
    }
    .prd-card-title-row {
        display: flex;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 4px 8px;
        margin-bottom: 5px;
    }
    .prd-card-name { font-size: 14px; font-weight: 700; color: #1F2937; line-height: 1.3; flex: 1 1 auto; min-width: 90px; }
    .prd-size-badge {
        background: #F3F4F6;
        color: #9CA3AF;
        border-radius: 6px;
        padding: 2px 7px;
        font-size: 10px;
        font-weight: 600;
        white-space: nowrap;
        flex-shrink: 0;
        margin-left: auto;
        margin-top: 2px;
    }
    .prd-card-desc {
        font-size: 12px;
        color: #6B7280;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    @media (max-width: 767px) {
        .prd-card-body { padding: 8px 10px 10px; }
        .prd-card-name { font-size: 12px; }
        .prd-card-desc { display: none; }
        .prd-card-img img { padding: 8px; }
    }
</style>
