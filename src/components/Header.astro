---
import company from "../data/company.json";
import navigation from "../data/navigation.json";
import products from "../data/products.json";
---

<div class="navbar bg-base-100 shadow-md sticky top-0 z-50 px-4 md:px-8">
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h8m-8 6h16"></path></svg
        >
      </div>
      <ul
        tabindex="0"
        class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52 text-base"
      >
        {
          navigation.main.map((item) => (
            <li>
              {item.children.length > 0 ? (
                <details>
                  <summary class="text-base">{item.title}</summary>
                  <ul class="p-2">
                    {item.children.map((child) => (
                      <li>
                        <a href={child.url} class="text-base">
                          {child.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.url} class="text-base">
                  {item.title}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>
    <a
      href="/"
      class="btn btn-ghost text-xl normal-case font-bold text-primary flex items-center gap-2"
    >
      <img src={`/${company.logo}`} alt={company.name} class="h-10 w-auto" />
      <span class="hidden sm:inline">喬新針織有限公司/永力新國際有限公司</span>
    </a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul
      class="menu menu-horizontal px-1 font-medium bg-base-100/50 backdrop-blur-sm rounded-full text-lg"
    >
      {
        navigation.main.map((item) => (
          <li>
            {item.children.length > 0 ? (
              <details>
                <summary>{item.title}</summary>
                <ul class="p-2 w-48 bg-base-100 shadow-xl border border-base-200">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.url}>{child.title}</a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={item.url}>{item.title}</a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
  <div class="navbar-end gap-2">
    <!-- 產品搜尋 -->
    <div class="dropdown dropdown-end" id="search-container">
      <button
        class="btn btn-ghost btn-circle"
        id="search-toggle"
        aria-label="搜尋產品"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </button>
      <div
        id="search-dropdown"
        class="dropdown-content mt-3 z-[100] bg-base-100 shadow-xl rounded-box w-80 md:w-96 hidden"
      >
        <div class="p-3 border-b border-base-200">
          <div class="form-control">
            <div class="input-group flex gap-2">
              <input
                type="text"
                id="search-input"
                placeholder="輸入產品名稱搜尋..."
                class="input input-bordered flex-1 focus:outline-primary"
                autocomplete="off"
              />
              <button class="btn btn-ghost btn-circle btn-sm" id="search-close">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
        <div id="search-results" class="max-h-80 overflow-y-auto">
          <div class="p-4 text-center text-base-content/50" id="search-hint">
            請輸入關鍵字開始搜尋
          </div>
        </div>
      </div>
    </div>

    <a
      href="tel:{company.contact.phone}"
      class="btn btn-primary btn-sm md:btn-md text-white"
    >
      聯絡我們
    </a>
  </div>
</div>

<!-- 搜尋功能的 JavaScript -->
<script define:vars={{ products }}>
  document.addEventListener("DOMContentLoaded", () => {
    const searchToggle = document.getElementById("search-toggle");
    const searchDropdown = document.getElementById("search-dropdown");
    const searchInput = document.getElementById("search-input");
    const searchResults = document.getElementById("search-results");
    const searchClose = document.getElementById("search-close");
    const searchHint = document.getElementById("search-hint");

    // 產品資料
    const productsData = products;

    // 切換搜尋下拉選單
    searchToggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      searchDropdown?.classList.toggle("hidden");
      if (!searchDropdown?.classList.contains("hidden")) {
        searchInput?.focus();
      }
    });

    // 關閉搜尋
    searchClose?.addEventListener("click", () => {
      searchDropdown?.classList.add("hidden");
      if (searchInput) searchInput.value = "";
      if (searchHint) searchHint.style.display = "block";
      if (searchResults) {
        searchResults.innerHTML =
          '<div class="p-4 text-center text-base-content/50" id="search-hint">請輸入關鍵字開始搜尋</div>';
      }
    });

    // 點擊外部關閉
    document.addEventListener("click", (e) => {
      const container = document.getElementById("search-container");
      if (container && !container.contains(e.target)) {
        searchDropdown?.classList.add("hidden");
      }
    });

    // 搜尋功能
    searchInput?.addEventListener("input", (e) => {
      const query = e.target.value.trim().toLowerCase();

      if (!query) {
        if (searchResults) {
          searchResults.innerHTML =
            '<div class="p-4 text-center text-base-content/50">請輸入關鍵字開始搜尋</div>';
        }
        return;
      }

      // 搜尋產品
      const results = productsData
        .filter((product) => {
          const name = product.name?.toLowerCase() || "";
          const description = product.description?.toLowerCase() || "";
          const category = product.category?.toLowerCase() || "";
          const tags = (product.tags || []).join(" ").toLowerCase();
          return (
            name.includes(query) ||
            description.includes(query) ||
            category.includes(query) ||
            tags.includes(query)
          );
        })
        .slice(0, 8); // 最多顯示8個結果

      if (results.length === 0) {
        if (searchResults) {
          searchResults.innerHTML = `
            <div class="p-4 text-center text-base-content/50">
              <p>找不到符合「${query}」的產品</p>
              <a href="/products" class="link link-primary mt-2 inline-block">瀏覽所有產品</a>
            </div>
          `;
        }
        return;
      }

      // 渲染搜尋結果
      if (searchResults) {
        searchResults.innerHTML = results
          .map(
            (product) => `
          <a 
            href="/products/${product.id}" 
            class="flex items-center gap-3 p-3 hover:bg-base-200 transition-colors border-b border-base-200 last:border-b-0"
          >
            <div class="avatar">
              <div class="w-12 h-12 rounded-lg overflow-hidden bg-base-200">
                <img 
                  src="/${product.image}" 
                  alt="${product.name}"
                  class="object-cover w-full h-full"
                  onerror="this.src='/images/placeholder.jpg'"
                />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-base-content truncate">${product.name}</p>
              <p class="text-sm text-base-content/60 truncate">${product.size || ""}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        `,
          )
          .join("");

        // 添加查看全部結果的連結
        if (results.length >= 8) {
          searchResults.innerHTML += `
            <a 
              href="/products?q=${encodeURIComponent(query)}" 
              class="block p-3 text-center text-primary hover:bg-base-200 transition-colors font-medium"
            >
              查看更多結果 →
            </a>
          `;
        }
      }
    });

    // 按 ESC 關閉搜尋
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        searchDropdown?.classList.add("hidden");
      }
    });
  });
</script>
